{% doc %}
  @prompt
    Create a premium "Contact Form + Support Details" section for a luxury Ayurvedic hair wellness brand called Livgenix.
    
    Design Goal:
    Make it easy for customers to contact Livgenix while reinforcing trust, responsiveness, and premium customer care.
    
    Layout:
    - Full-width white section.
    - Two-column responsive layout.
    - Left column (60%): Contact Form.
    - Right column (40%): Support Details.
    - Vertically aligned.
    - Maximum content width: 1400px.
    - Large spacing between columns.
    
    LEFT COLUMN
    
    Small eyebrow:
    SEND A MESSAGE
    
    Heading:
    How Can We Help You?
    
    Short description:
    Have a question about your order, products, or your hair wellness journey? Fill out the form below and our team will get back to you as soon as possible.
    
    Premium contact form with rounded inputs:
    
    • Full Name
    • Email Address
    • Phone Number
    • Subject
    • Message
    
    Large primary button:
    Send Message
    
    Form Style:
    - Rounded inputs (14px radius)
    - Soft borders
    - Comfortable spacing
    - Large textarea
    - Premium modern appearance
    - No heavy shadows
    
    RIGHT COLUMN
    
    Display a premium support information card.
    
    Heading:
    Support Information
    
    Include the following blocks with simple line icons:
    
    📧 Email Support
    support@livgenix.com
    
    💬 WhatsApp Support
    Available during business hours
    
    🕒 Response Time
    Within 24 Business Hours
    
    🕘 Customer Support Hours
    Monday – Saturday
    9:00 AM – 6:00 PM (IST)
    
    🌿 Product Guidance
    Need help choosing the right routine?
    Our wellness team is happy to help.
    
    At the bottom of the card include a subtle note:
    
    "We're committed to providing thoughtful, timely support for every customer."
    
    Design Style:
    - Luxury editorial aesthetic.
    - Inspired by Aesop, Ritual, Apple and premium skincare brands.
    - White background.
    - Rounded support card (24px radius).
    - Very subtle border (#ECE2CE).
    - No gradients.
    - No heavy shadows.
    - Large whitespace.
    - Smooth fade-up animation.
    
    Color Palette:
    Background: #FFFFFF
    Heading: #2F3324
    Accent: #BE9A5C
    Primary Button: #6F764F
    Body Text: #6B705C
    Borders: #ECE2CE
    
    The section should feel welcoming, premium, and trustworthy while remaining highly functional.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-contact-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 60% 40%;
    gap: {{ block.settings.column_gap }}px;
    align-items: start;
  }

  .ai-contact-form-column-{{ ai_gen_id }} {
    padding-right: 40px;
  }

  .ai-contact-eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_size }}px;
    color: {{ block.settings.accent_color }};
    letter-spacing: 2px;
    margin-bottom: 16px;
    font-weight: 500;
    text-transform: uppercase;
  }

  .ai-contact-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 20px;
    line-height: 1.2;
    font-weight: 700;
  }

  .ai-contact-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.body_text_color }};
    line-height: 1.6;
    margin-bottom: 40px;
  }

  .ai-contact-form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-contact-form-group-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-contact-label-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.heading_color }};
    font-weight: 500;
  }

  .ai-contact-input-{{ ai_gen_id }},
  .ai-contact-textarea-{{ ai_gen_id }} {
    width: 100%;
    padding: 14px 18px;
    border: 1px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 15px;
    color: {{ block.settings.heading_color }};
    background-color: {{ block.settings.background_color }};
    transition: border-color 0.3s ease;
  }

  .ai-contact-input-{{ ai_gen_id }}:focus,
  .ai-contact-textarea-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.accent_color }};
  }

  .ai-contact-textarea-{{ ai_gen_id }} {
    min-height: 140px;
    resize: vertical;
    font-family: inherit;
  }

  .ai-contact-button-{{ ai_gen_id }} {
    padding: 16px 40px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    align-self: flex-start;
    margin-top: 10px;
  }

  .ai-contact-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    transform: translateY(-2px);
  }

  .ai-contact-support-column-{{ ai_gen_id }} {
    position: sticky;
    top: 40px;
  }

  .ai-contact-support-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    border: 1px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 40px 32px;
    opacity: 0;
    transform: translateY(20px);
  }

  .ai-contact-support-card-{{ ai_gen_id }}.ai-visible-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .ai-contact-support-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.support_heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 32px;
    font-weight: 700;
  }

  .ai-contact-support-items-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 28px;
    margin-bottom: 32px;
  }

  .ai-contact-support-item-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .ai-contact-support-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    color: {{ block.settings.accent_color }};
    font-size: 24px;
    line-height: 1;
  }

  .ai-contact-support-content-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-contact-support-item-title-{{ ai_gen_id }} {
    font-size: 15px;
    color: {{ block.settings.heading_color }};
    font-weight: 600;
    margin: 0 0 6px;
  }

  .ai-contact-support-item-text-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.body_text_color }};
    line-height: 1.5;
    margin: 0;
  }

  .ai-contact-support-note-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.body_text_color }};
    line-height: 1.6;
    font-style: italic;
    padding-top: 24px;
    border-top: 1px solid {{ block.settings.border_color }};
  }

  .ai-contact-success-{{ ai_gen_id }} {
    padding: 16px 20px;
    background-color: #e8f5e9;
    color: #2e7d32;
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-bottom: 20px;
    font-size: 15px;
  }

  .ai-contact-error-{{ ai_gen_id }} {
    padding: 16px 20px;
    background-color: #ffebee;
    color: #c62828;
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-bottom: 20px;
    font-size: 15px;
  }

  @media screen and (max-width: 989px) {
    .ai-contact-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 60px;
    }

    .ai-contact-form-column-{{ ai_gen_id }} {
      padding-right: 0;
    }

    .ai-contact-support-column-{{ ai_gen_id }} {
      position: static;
    }

    .ai-contact-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-contact-support-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.support_heading_size }}px * 0.9);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-contact-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.6 }}px 16px {{ block.settings.section_padding_bottom | times: 0.6 }}px;
    }

    .ai-contact-container-{{ ai_gen_id }} {
      gap: 40px;
    }

    .ai-contact-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.65);
    }

    .ai-contact-button-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-contact-support-card-{{ ai_gen_id }} {
      padding: 32px 24px;
    }
  }
{% endstyle %}

<contact-section-{{ ai_gen_id }} class="ai-contact-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-container-{{ ai_gen_id }}">
    <div class="ai-contact-form-column-{{ ai_gen_id }}">
      {% if block.settings.eyebrow != blank %}
        <div class="ai-contact-eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow }}</div>
      {% endif %}

      {% if block.settings.heading != blank %}
        <h2 class="ai-contact-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.description != blank %}
        <div class="ai-contact-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
      {% endif %}

      {% form 'contact' %}
        {% if form.posted_successfully? %}
          <div class="ai-contact-success-{{ ai_gen_id }}">
            {{ block.settings.success_message }}
          </div>
        {% endif %}

        {% if form.errors %}
          <div class="ai-contact-error-{{ ai_gen_id }}">
            {{ form.errors.messages | first }}
          </div>
        {% endif %}

        <div class="ai-contact-form-{{ ai_gen_id }}">
          <div class="ai-contact-form-group-{{ ai_gen_id }}">
            <label class="ai-contact-label-{{ ai_gen_id }}" for="contact-name-{{ ai_gen_id }}">
              Full Name
            </label>
            <input
              type="text"
              id="contact-name-{{ ai_gen_id }}"
              name="contact[name]"
              class="ai-contact-input-{{ ai_gen_id }}"
              required
            >
          </div>

          <div class="ai-contact-form-group-{{ ai_gen_id }}">
            <label class="ai-contact-label-{{ ai_gen_id }}" for="contact-email-{{ ai_gen_id }}">
              Email Address
            </label>
            <input
              type="email"
              id="contact-email-{{ ai_gen_id }}"
              name="contact[email]"
              class="ai-contact-input-{{ ai_gen_id }}"
              autocomplete="email"
              required
            >
          </div>

          <div class="ai-contact-form-group-{{ ai_gen_id }}">
            <label class="ai-contact-label-{{ ai_gen_id }}" for="contact-phone-{{ ai_gen_id }}">
              Phone Number
            </label>
            <input
              type="tel"
              id="contact-phone-{{ ai_gen_id }}"
              name="contact[phone]"
              class="ai-contact-input-{{ ai_gen_id }}"
              autocomplete="tel"
            >
          </div>

          <div class="ai-contact-form-group-{{ ai_gen_id }}">
            <label class="ai-contact-label-{{ ai_gen_id }}" for="contact-subject-{{ ai_gen_id }}">
              Subject
            </label>
            <input
              type="text"
              id="contact-subject-{{ ai_gen_id }}"
              name="contact[subject]"
              class="ai-contact-input-{{ ai_gen_id }}"
              required
            >
          </div>

          <div class="ai-contact-form-group-{{ ai_gen_id }}">
            <label class="ai-contact-label-{{ ai_gen_id }}" for="contact-message-{{ ai_gen_id }}">
              Message
            </label>
            <textarea
              id="contact-message-{{ ai_gen_id }}"
              name="contact[body]"
              class="ai-contact-textarea-{{ ai_gen_id }}"
              required
            ></textarea>
          </div>

          <button type="submit" class="ai-contact-button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </button>
        </div>
      {% endform %}
    </div>

    <div class="ai-contact-support-column-{{ ai_gen_id }}">
      <div class="ai-contact-support-card-{{ ai_gen_id }}" data-animate>
        <h3 class="ai-contact-support-heading-{{ ai_gen_id }}">{{ block.settings.support_heading }}</h3>

        <div class="ai-contact-support-items-{{ ai_gen_id }}">
          {% if block.settings.show_email %}
            <div class="ai-contact-support-item-{{ ai_gen_id }}">
              <div class="ai-contact-support-icon-{{ ai_gen_id }}">📧</div>
              <div class="ai-contact-support-content-{{ ai_gen_id }}">
                <h4 class="ai-contact-support-item-title-{{ ai_gen_id }}">{{ block.settings.email_title }}</h4>
                <p class="ai-contact-support-item-text-{{ ai_gen_id }}">{{ block.settings.email_text }}</p>
              </div>
            </div>
          {% endif %}

          {% if block.settings.show_whatsapp %}
            <div class="ai-contact-support-item-{{ ai_gen_id }}">
              <div class="ai-contact-support-icon-{{ ai_gen_id }}">💬</div>
              <div class="ai-contact-support-content-{{ ai_gen_id }}">
                <h4 class="ai-contact-support-item-title-{{ ai_gen_id }}">{{ block.settings.whatsapp_title }}</h4>
                <p class="ai-contact-support-item-text-{{ ai_gen_id }}">{{ block.settings.whatsapp_text }}</p>
              </div>
            </div>
          {% endif %}

          {% if block.settings.show_response_time %}
            <div class="ai-contact-support-item-{{ ai_gen_id }}">
              <div class="ai-contact-support-icon-{{ ai_gen_id }}">🕒</div>
              <div class="ai-contact-support-content-{{ ai_gen_id }}">
                <h4 class="ai-contact-support-item-title-{{ ai_gen_id }}">{{ block.settings.response_time_title }}</h4>
                <p class="ai-contact-support-item-text-{{ ai_gen_id }}">{{ block.settings.response_time_text }}</p>
              </div>
            </div>
          {% endif %}

          {% if block.settings.show_hours %}
            <div class="ai-contact-support-item-{{ ai_gen_id }}">
              <div class="ai-contact-support-icon-{{ ai_gen_id }}">🕘</div>
              <div class="ai-contact-support-content-{{ ai_gen_id }}">
                <h4 class="ai-contact-support-item-title-{{ ai_gen_id }}">{{ block.settings.hours_title }}</h4>
                <p class="ai-contact-support-item-text-{{ ai_gen_id }}">{{ block.settings.hours_text }}</p>
              </div>
            </div>
          {% endif %}

          {% if block.settings.show_guidance %}
            <div class="ai-contact-support-item-{{ ai_gen_id }}">
              <div class="ai-contact-support-icon-{{ ai_gen_id }}">🌿</div>
              <div class="ai-contact-support-content-{{ ai_gen_id }}">
                <h4 class="ai-contact-support-item-title-{{ ai_gen_id }}">{{ block.settings.guidance_title }}</h4>
                <p class="ai-contact-support-item-text-{{ ai_gen_id }}">{{ block.settings.guidance_text }}</p>
              </div>
            </div>
          {% endif %}
        </div>

        {% if block.settings.support_note != blank %}
          <div class="ai-contact-support-note-{{ ai_gen_id }}">
            {{ block.settings.support_note }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</contact-section-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAnimation();
      }

      setupAnimation() {
        const card = this.querySelector('[data-animate]');
        if (!card) return;

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('ai-visible-{{ ai_gen_id }}');
              observer.unobserve(entry.target);
            }
          });
        }, {
          threshold: 0.2
        });

        observer.observe(card);
      }
    }

    customElements.define('contact-section-{{ ai_gen_id }}', ContactSection{{ ai_gen_id }});
  })();
</script>

