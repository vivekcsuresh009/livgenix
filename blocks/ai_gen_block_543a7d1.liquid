{% doc %}
  @prompt
    Create a premium "Contact Form + Support Details" section for a luxury Ayurvedic hair
    wellness brand called Livgenix.

    Redesigned per brand design system: rounded 18px+ inputs, floating labels, icons inside
    inputs, gold focus state, premium stacked support cards on soft cream backgrounds with
    hover elevation, elegant CSS-only validation styling, large touch-friendly fields,
    micro interactions, CSS custom properties. Preserves the native Shopify `contact` form
    handling exactly as-is.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-section-{{ ai_gen_id }} {
    --lg-heading: {{ block.settings.heading_color }};
    --lg-gold: {{ block.settings.accent_color }};
    --lg-text: {{ block.settings.body_text_color }};
    --lg-border: {{ block.settings.border_color }};
    --lg-button: {{ block.settings.button_color }};
    --lg-button-hover: {{ block.settings.button_hover_color }};
    --lg-cream: {{ block.settings.card_background_color }};
    --lg-radius-input: {{ block.settings.input_border_radius }}px;
    --lg-radius-button: {{ block.settings.button_border_radius }}px;
    --lg-radius-card: {{ block.settings.card_border_radius }}px;

    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-contact-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 60% 40%;
    gap: {{ block.settings.column_gap }}px;
    align-items: start;
  }

  .ai-contact-form-column-{{ ai_gen_id }} {
    padding-right: 40px;
  }

  .ai-contact-eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_size }}px;
    color: var(--lg-gold);
    letter-spacing: 2.5px;
    margin-bottom: 16px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .ai-contact-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: var(--lg-heading);
    margin: 0 0 20px;
    line-height: 1.2;
    font-weight: 700;
  }

  .ai-contact-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: var(--lg-text);
    line-height: 1.7;
    margin-bottom: 44px;
  }

  .ai-contact-form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .ai-contact-form-row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px;
  }

  .ai-contact-form-group-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-contact-input-wrap-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    align-items: center;
  }

  .ai-contact-input-icon-{{ ai_gen_id }} {
    position: absolute;
    left: 18px;
    top: 22px;
    width: 18px;
    height: 18px;
    stroke: var(--lg-text);
    fill: none;
    stroke-width: 1.75;
    stroke-linecap: round;
    stroke-linejoin: round;
    opacity: 0.65;
    pointer-events: none;
    transition: stroke 250ms ease, opacity 250ms ease;
  }

  .ai-contact-input-wrap-{{ ai_gen_id }}.ai-contact-input-wrap--textarea-{{ ai_gen_id }} .ai-contact-input-icon-{{ ai_gen_id }} {
    top: 24px;
  }

  .ai-contact-input-{{ ai_gen_id }},
  .ai-contact-textarea-{{ ai_gen_id }} {
    width: 100%;
    padding: 26px 18px 10px 48px;
    border: 1.5px solid var(--lg-border);
    border-radius: var(--lg-radius-input);
    font-size: 16px;
    font-family: inherit;
    color: var(--lg-heading);
    background-color: {{ block.settings.input_background_color }};
    transition: border-color 250ms ease, box-shadow 250ms ease, background-color 250ms ease;
    min-height: 64px;
  }

  .ai-contact-textarea-{{ ai_gen_id }} {
    min-height: 160px;
    resize: vertical;
    padding-top: 30px;
  }

  .ai-contact-input-{{ ai_gen_id }}:hover,
  .ai-contact-textarea-{{ ai_gen_id }}:hover {
    border-color: rgb(190 154 92 / 0.5);
  }

  .ai-contact-input-{{ ai_gen_id }}:focus,
  .ai-contact-textarea-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: var(--lg-gold);
    box-shadow: 0 0 0 4px rgb(190 154 92 / 0.14);
    background-color: #ffffff;
  }

  .ai-contact-input-{{ ai_gen_id }}:focus ~ .ai-contact-input-icon-{{ ai_gen_id }},
  .ai-contact-textarea-{{ ai_gen_id }}:focus ~ .ai-contact-input-icon-{{ ai_gen_id }} {
    stroke: var(--lg-gold);
    opacity: 1;
  }

  .ai-contact-input-{{ ai_gen_id }}:invalid:not(:placeholder-shown):not(:focus),
  .ai-contact-textarea-{{ ai_gen_id }}:invalid:not(:placeholder-shown):not(:focus) {
    border-color: #c2695a;
  }

  .ai-contact-label-{{ ai_gen_id }} {
    position: absolute;
    left: 48px;
    top: 22px;
    font-size: 16px;
    color: var(--lg-text);
    font-weight: 500;
    pointer-events: none;
    transform-origin: left top;
    transition: transform 200ms ease, top 200ms ease, color 200ms ease;
  }

  .ai-contact-input-{{ ai_gen_id }}:focus ~ .ai-contact-label-{{ ai_gen_id }},
  .ai-contact-input-{{ ai_gen_id }}:not(:placeholder-shown) ~ .ai-contact-label-{{ ai_gen_id }},
  .ai-contact-textarea-{{ ai_gen_id }}:focus ~ .ai-contact-label-{{ ai_gen_id }},
  .ai-contact-textarea-{{ ai_gen_id }}:not(:placeholder-shown) ~ .ai-contact-label-{{ ai_gen_id }} {
    top: 9px;
    transform: scale(0.72);
    color: var(--lg-gold);
    font-weight: 600;
  }

  .ai-contact-optional-{{ ai_gen_id }} {
    font-weight: 400;
    opacity: 0.6;
  }

  .ai-contact-button-{{ ai_gen_id }} {
    padding: 19px 44px;
    background-color: var(--lg-button);
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: var(--lg-radius-button);
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition: transform 250ms ease, box-shadow 250ms ease, background-color 250ms ease;
    align-self: flex-start;
    margin-top: 10px;
  }

  .ai-contact-button-{{ ai_gen_id }}:hover {
    background-color: var(--lg-button-hover);
    transform: translateY(-3px);
    box-shadow: 0 14px 28px rgb(111 118 79 / 0.24);
  }

  .ai-contact-button-{{ ai_gen_id }}:active {
    transform: translateY(-1px);
  }

  .ai-contact-button-{{ ai_gen_id }}:focus-visible {
    outline: 2px solid var(--lg-button);
    outline-offset: 3px;
  }

  .ai-contact-support-column-{{ ai_gen_id }} {
    position: sticky;
    top: 40px;
  }

  .ai-contact-support-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.support_heading_size }}px;
    color: var(--lg-heading);
    margin: 0 0 24px;
    font-weight: 700;
  }

  .ai-contact-support-items-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-contact-support-item-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    background-color: var(--lg-cream);
    border: 1px solid var(--lg-border);
    border-radius: var(--lg-radius-card);
    padding: 22px 22px;
    opacity: 0;
    transform: translateY(16px);
    transition: transform 300ms ease, box-shadow 300ms ease, opacity 300ms ease;
  }

  .ai-contact-support-item-{{ ai_gen_id }}.ai-visible-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-contact-support-item-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 14px 30px rgb(47 51 36 / 0.08);
  }

  .ai-contact-support-icon-wrap-{{ ai_gen_id }} {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: #ffffff;
  }

  .ai-contact-support-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    stroke: var(--lg-gold);
    fill: none;
    stroke-width: 1.75;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ai-contact-support-content-{{ ai_gen_id }} {
    flex: 1;
    padding-top: 2px;
  }

  .ai-contact-support-item-title-{{ ai_gen_id }} {
    font-size: 15px;
    color: var(--lg-heading);
    font-weight: 600;
    margin: 0 0 4px;
  }

  .ai-contact-support-item-text-{{ ai_gen_id }} {
    font-size: 14px;
    color: var(--lg-text);
    line-height: 1.55;
    margin: 0;
    white-space: pre-line;
  }

  .ai-contact-support-note-{{ ai_gen_id }} {
    font-size: 13px;
    color: var(--lg-text);
    line-height: 1.6;
    font-style: italic;
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid var(--lg-border);
  }

  .ai-contact-success-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 18px 20px;
    background-color: #eef3e6;
    color: #3f5d33;
    border-radius: var(--lg-radius-input);
    margin-bottom: 20px;
    font-size: 15px;
  }

  .ai-contact-error-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 18px 20px;
    background-color: #f7e9e6;
    color: #8a3c2c;
    border-radius: var(--lg-radius-input);
    margin-bottom: 20px;
    font-size: 15px;
  }

  .ai-contact-message-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-contact-support-item-{{ ai_gen_id }},
    .ai-contact-button-{{ ai_gen_id }},
    .ai-contact-input-{{ ai_gen_id }},
    .ai-contact-textarea-{{ ai_gen_id }},
    .ai-contact-label-{{ ai_gen_id }} {
      transition: none;
    }
  }

  @media screen and (max-width: 989px) {
    .ai-contact-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 60px;
    }

    .ai-contact-form-column-{{ ai_gen_id }} {
      padding-right: 0;
    }

    .ai-contact-support-column-{{ ai_gen_id }} {
      position: static;
    }

    .ai-contact-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-contact-support-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.support_heading_size }}px * 0.9);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-contact-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.6 }}px 16px {{ block.settings.section_padding_bottom | times: 0.6 }}px;
    }

    .ai-contact-container-{{ ai_gen_id }} {
      gap: 40px;
    }

    .ai-contact-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.65);
    }

    .ai-contact-form-row-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 22px;
    }

    .ai-contact-button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<contact-section-{{ ai_gen_id }} class="ai-contact-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-container-{{ ai_gen_id }}">
    <div class="ai-contact-form-column-{{ ai_gen_id }}">
      {% if block.settings.eyebrow != blank %}
        <div class="ai-contact-eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow }}</div>
      {% endif %}

      {% if block.settings.heading != blank %}
        <h2 class="ai-contact-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.description != blank %}
        <div class="ai-contact-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
      {% endif %}

      {% form 'contact' %}
        {% if form.posted_successfully? %}
          <div class="ai-contact-success-{{ ai_gen_id }}" role="status">
            <svg class="ai-contact-message-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20 6L9 17l-5-5" />
            </svg>
            {{ block.settings.success_message }}
          </div>
        {% endif %}

        {% if form.errors %}
          <div class="ai-contact-error-{{ ai_gen_id }}" role="alert">
            <svg class="ai-contact-message-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="9" />
              <line x1="12" y1="8" x2="12" y2="13" />
              <line x1="12" y1="16" x2="12.01" y2="16" />
            </svg>
            {{ form.errors.messages | first }}
          </div>
        {% endif %}

        <div class="ai-contact-form-{{ ai_gen_id }}">
          <div class="ai-contact-form-row-{{ ai_gen_id }}">
            <div class="ai-contact-form-group-{{ ai_gen_id }}">
              <div class="ai-contact-input-wrap-{{ ai_gen_id }}">
                <input
                  type="text"
                  id="contact-name-{{ ai_gen_id }}"
                  name="contact[name]"
                  class="ai-contact-input-{{ ai_gen_id }}"
                  placeholder=" "
                  autocomplete="name"
                  required
                >
                <svg class="ai-contact-input-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                  <circle cx="12" cy="7" r="4" />
                </svg>
                <label class="ai-contact-label-{{ ai_gen_id }}" for="contact-name-{{ ai_gen_id }}">
                  Full Name
                </label>
              </div>
            </div>

            <div class="ai-contact-form-group-{{ ai_gen_id }}">
              <div class="ai-contact-input-wrap-{{ ai_gen_id }}">
                <input
                  type="email"
                  id="contact-email-{{ ai_gen_id }}"
                  name="contact[email]"
                  class="ai-contact-input-{{ ai_gen_id }}"
                  placeholder=" "
                  autocomplete="email"
                  required
                >
                <svg class="ai-contact-input-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" aria-hidden="true">
                  <rect x="3" y="5" width="18" height="14" rx="2" />
                  <path d="M3 7l9 6 9-6" />
                </svg>
                <label class="ai-contact-label-{{ ai_gen_id }}" for="contact-email-{{ ai_gen_id }}">
                  Email Address
                </label>
              </div>
            </div>
          </div>

          <div class="ai-contact-form-row-{{ ai_gen_id }}">
            <div class="ai-contact-form-group-{{ ai_gen_id }}">
              <div class="ai-contact-input-wrap-{{ ai_gen_id }}">
                <input
                  type="tel"
                  id="contact-phone-{{ ai_gen_id }}"
                  name="contact[phone]"
                  class="ai-contact-input-{{ ai_gen_id }}"
                  placeholder=" "
                  autocomplete="tel"
                >
                <svg class="ai-contact-input-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                </svg>
                <label class="ai-contact-label-{{ ai_gen_id }}" for="contact-phone-{{ ai_gen_id }}">
                  Phone Number <span class="ai-contact-optional-{{ ai_gen_id }}">(optional)</span>
                </label>
              </div>
            </div>

            <div class="ai-contact-form-group-{{ ai_gen_id }}">
              <div class="ai-contact-input-wrap-{{ ai_gen_id }}">
                <input
                  type="text"
                  id="contact-subject-{{ ai_gen_id }}"
                  name="contact[subject]"
                  class="ai-contact-input-{{ ai_gen_id }}"
                  placeholder=" "
                  required
                >
                <svg class="ai-contact-input-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M4 4h16v12H8l-4 4V4z" />
                </svg>
                <label class="ai-contact-label-{{ ai_gen_id }}" for="contact-subject-{{ ai_gen_id }}">
                  Subject
                </label>
              </div>
            </div>
          </div>

          <div class="ai-contact-form-group-{{ ai_gen_id }}">
            <div class="ai-contact-input-wrap-{{ ai_gen_id }} ai-contact-input-wrap--textarea-{{ ai_gen_id }}">
              <textarea
                id="contact-message-{{ ai_gen_id }}"
                name="contact[body]"
                class="ai-contact-textarea-{{ ai_gen_id }}"
                placeholder=" "
                required
              ></textarea>
              <svg class="ai-contact-input-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
              </svg>
              <label class="ai-contact-label-{{ ai_gen_id }}" for="contact-message-{{ ai_gen_id }}">
                Message
              </label>
            </div>
          </div>

          <button type="submit" class="ai-contact-button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </button>
        </div>
      {% endform %}
    </div>

    <div class="ai-contact-support-column-{{ ai_gen_id }}">
      <h3 class="ai-contact-support-heading-{{ ai_gen_id }}">{{ block.settings.support_heading }}</h3>

      <div class="ai-contact-support-items-{{ ai_gen_id }}">
        {% if block.settings.show_email %}
          <div class="ai-contact-support-item-{{ ai_gen_id }}" data-animate>
            <div class="ai-contact-support-icon-wrap-{{ ai_gen_id }}">
              <svg class="ai-contact-support-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" aria-hidden="true">
                <rect x="3" y="5" width="18" height="14" rx="2" />
                <path d="M3 7l9 6 9-6" />
              </svg>
            </div>
            <div class="ai-contact-support-content-{{ ai_gen_id }}">
              <h4 class="ai-contact-support-item-title-{{ ai_gen_id }}">{{ block.settings.email_title }}</h4>
              <p class="ai-contact-support-item-text-{{ ai_gen_id }}">{{ block.settings.email_text }}</p>
            </div>
          </div>
        {% endif %}

        {% if block.settings.show_whatsapp %}
          <div class="ai-contact-support-item-{{ ai_gen_id }}" data-animate>
            <div class="ai-contact-support-icon-wrap-{{ ai_gen_id }}">
              <svg class="ai-contact-support-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
              </svg>
            </div>
            <div class="ai-contact-support-content-{{ ai_gen_id }}">
              <h4 class="ai-contact-support-item-title-{{ ai_gen_id }}">{{ block.settings.whatsapp_title }}</h4>
              <p class="ai-contact-support-item-text-{{ ai_gen_id }}">{{ block.settings.whatsapp_text }}</p>
            </div>
          </div>
        {% endif %}

        {% if block.settings.show_response_time %}
          <div class="ai-contact-support-item-{{ ai_gen_id }}" data-animate>
            <div class="ai-contact-support-icon-wrap-{{ ai_gen_id }}">
              <svg class="ai-contact-support-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" aria-hidden="true">
                <circle cx="12" cy="12" r="9" />
                <path d="M12 7v5l3.2 2" />
              </svg>
            </div>
            <div class="ai-contact-support-content-{{ ai_gen_id }}">
              <h4 class="ai-contact-support-item-title-{{ ai_gen_id }}">{{ block.settings.response_time_title }}</h4>
              <p class="ai-contact-support-item-text-{{ ai_gen_id }}">{{ block.settings.response_time_text }}</p>
            </div>
          </div>
        {% endif %}

        {% if block.settings.show_hours %}
          <div class="ai-contact-support-item-{{ ai_gen_id }}" data-animate>
            <div class="ai-contact-support-icon-wrap-{{ ai_gen_id }}">
              <svg class="ai-contact-support-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" aria-hidden="true">
                <rect x="3" y="4" width="18" height="17" rx="2" />
                <path d="M3 9h18" />
                <path d="M8 2v4M16 2v4" />
              </svg>
            </div>
            <div class="ai-contact-support-content-{{ ai_gen_id }}">
              <h4 class="ai-contact-support-item-title-{{ ai_gen_id }}">{{ block.settings.hours_title }}</h4>
              <p class="ai-contact-support-item-text-{{ ai_gen_id }}">{{ block.settings.hours_text }}</p>
            </div>
          </div>
        {% endif %}

        {% if block.settings.show_guidance %}
          <div class="ai-contact-support-item-{{ ai_gen_id }}" data-animate>
            <div class="ai-contact-support-icon-wrap-{{ ai_gen_id }}">
              <svg class="ai-contact-support-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M3 21c7-1 11-5 12-12" />
                <path d="M15 9c-3 0-5-2-5-5 3 0 5 2 5 5z" />
              </svg>
            </div>
            <div class="ai-contact-support-content-{{ ai_gen_id }}">
              <h4 class="ai-contact-support-item-title-{{ ai_gen_id }}">{{ block.settings.guidance_title }}</h4>
              <p class="ai-contact-support-item-text-{{ ai_gen_id }}">{{ block.settings.guidance_text }}</p>
            </div>
          </div>
        {% endif %}
      </div>

      {% if block.settings.support_note != blank %}
        <div class="ai-contact-support-note-{{ ai_gen_id }}">
          {{ block.settings.support_note }}
        </div>
      {% endif %}
    </div>
  </div>
</contact-section-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactSection{{ ai_gen_id }} extends HTMLElement {
      connectedCallback() {
        this.setupAnimation();
      }

      setupAnimation() {
        const cards = this.querySelectorAll('[data-animate]');
        if (!cards.length) return;

        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          cards.forEach((card) => card.classList.add('ai-visible-{{ ai_gen_id }}'));
          return;
        }

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry, index) => {
            if (entry.isIntersecting) {
              window.setTimeout(() => {
                entry.target.classList.add('ai-visible-{{ ai_gen_id }}');
              }, index * 80);
              observer.unobserve(entry.target);
            }
          });
        }, {
          threshold: 0.2
        });

        cards.forEach((card) => observer.observe(card));
      }
    }

    if (!customElements.get('contact-section-{{ ai_gen_id }}')) {
      customElements.define('contact-section-{{ ai_gen_id }}', ContactSection{{ ai_gen_id }});
    }
  })();
</script>

