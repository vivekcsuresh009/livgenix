{% doc %}
  @prompt
    Create a four-step usage guide.
    
    Headline:
    Simple Daily Scalp Care
    
    Step 1
    Apply 5–10 ml.
    
    Step 2
    Massage for 5–10 minutes.
    
    Step 3
    Leave for 15–30 minutes.
    
    Step 4
    Wash using Coconeela Herbal Cleanser Shampoo.
    
    Below include:
    
    Recommended Frequency
    
    Routine Care
    2–3 times weekly
    
    Hair Fall & Dandruff Care
    3–4 times weekly
    
    Design:
    Illustrated numbered cards with connecting arrows.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-usage-guide-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-usage-guide-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-usage-guide-headline-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ block.settings.headline_size }}px;
    color: {{ block.settings.headline_color }};
    margin: 0 0 {{ block.settings.headline_spacing }}px;
    font-weight: 600;
  }

  .ai-usage-guide-steps-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.step_gap }}px;
    margin-bottom: {{ block.settings.frequency_spacing }}px;
    position: relative;
  }

  .ai-usage-guide-step-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-align: center;
    box-shadow: {{ block.settings.card_shadow }};
    position: relative;
  }

  .ai-usage-guide-step-number-{{ ai_gen_id }} {
    width: {{ block.settings.number_size }}px;
    height: {{ block.settings.number_size }}px;
    background-color: {{ block.settings.number_background }};
    color: {{ block.settings.number_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: {{ block.settings.number_font_size }}px;
    font-weight: 700;
    margin: 0 auto {{ block.settings.number_spacing }}px;
  }

  .ai-usage-guide-step-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.step_title_size }}px;
    color: {{ block.settings.step_title_color }};
    margin: 0 0 8px;
    font-weight: 600;
  }

  .ai-usage-guide-step-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.step_description_size }}px;
    color: {{ block.settings.step_description_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-usage-guide-arrow-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.number_size | divided_by: 2 }}px;
    left: calc(100% + {{ block.settings.step_gap | divided_by: 2 }}px - 20px);
    transform: translateY(-50%);
    color: {{ block.settings.arrow_color }};
    font-size: 24px;
    z-index: 1;
  }

  .ai-usage-guide-step-{{ ai_gen_id }}:last-child .ai-usage-guide-arrow-{{ ai_gen_id }} {
    display: none;
  }

  .ai-usage-guide-frequency-{{ ai_gen_id }} {
    background-color: {{ block.settings.frequency_background }};
    border-radius: {{ block.settings.frequency_border_radius }}px;
    padding: {{ block.settings.frequency_padding }}px;
  }

  .ai-usage-guide-frequency-title-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ block.settings.frequency_title_size }}px;
    color: {{ block.settings.frequency_title_color }};
    margin: 0 0 {{ block.settings.frequency_title_spacing }}px;
    font-weight: 600;
  }

  .ai-usage-guide-frequency-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.frequency_gap }}px;
    max-width: 800px;
    margin: 0 auto;
  }

  .ai-usage-guide-frequency-item-{{ ai_gen_id }} {
    text-align: center;
    padding: {{ block.settings.frequency_item_padding }}px;
    background-color: {{ block.settings.frequency_item_background }};
    border-radius: {{ block.settings.frequency_item_border_radius }}px;
  }

  .ai-usage-guide-frequency-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.frequency_label_size }}px;
    color: {{ block.settings.frequency_label_color }};
    margin: 0 0 8px;
    font-weight: 600;
  }

  .ai-usage-guide-frequency-value-{{ ai_gen_id }} {
    font-size: {{ block.settings.frequency_value_size }}px;
    color: {{ block.settings.frequency_value_color }};
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-usage-guide-steps-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }

    .ai-usage-guide-step-{{ ai_gen_id }}:nth-child(2) .ai-usage-guide-arrow-{{ ai_gen_id }},
    .ai-usage-guide-step-{{ ai_gen_id }}:nth-child(4) .ai-usage-guide-arrow-{{ ai_gen_id }} {
      display: none;
    }

    .ai-usage-guide-arrow-{{ ai_gen_id }} {
      display: block;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-usage-guide-steps-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-usage-guide-arrow-{{ ai_gen_id }} {
      display: none;
    }

    .ai-usage-guide-frequency-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<div class="ai-usage-guide-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-usage-guide-container-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h2 class="ai-usage-guide-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
    {% endif %}

    <div class="ai-usage-guide-steps-{{ ai_gen_id }}">
      {% if block.settings.step_1_title != blank %}
        <div class="ai-usage-guide-step-{{ ai_gen_id }}">
          <div class="ai-usage-guide-step-number-{{ ai_gen_id }}">1</div>
          <h3 class="ai-usage-guide-step-title-{{ ai_gen_id }}">{{ block.settings.step_1_title }}</h3>
          <p class="ai-usage-guide-step-description-{{ ai_gen_id }}">{{ block.settings.step_1_description }}</p>
          <div class="ai-usage-guide-arrow-{{ ai_gen_id }}">→</div>
        </div>
      {% endif %}

      {% if block.settings.step_2_title != blank %}
        <div class="ai-usage-guide-step-{{ ai_gen_id }}">
          <div class="ai-usage-guide-step-number-{{ ai_gen_id }}">2</div>
          <h3 class="ai-usage-guide-step-title-{{ ai_gen_id }}">{{ block.settings.step_2_title }}</h3>
          <p class="ai-usage-guide-step-description-{{ ai_gen_id }}">{{ block.settings.step_2_description }}</p>
          <div class="ai-usage-guide-arrow-{{ ai_gen_id }}">→</div>
        </div>
      {% endif %}

      {% if block.settings.step_3_title != blank %}
        <div class="ai-usage-guide-step-{{ ai_gen_id }}">
          <div class="ai-usage-guide-step-number-{{ ai_gen_id }}">3</div>
          <h3 class="ai-usage-guide-step-title-{{ ai_gen_id }}">{{ block.settings.step_3_title }}</h3>
          <p class="ai-usage-guide-step-description-{{ ai_gen_id }}">{{ block.settings.step_3_description }}</p>
          <div class="ai-usage-guide-arrow-{{ ai_gen_id }}">→</div>
        </div>
      {% endif %}

      {% if block.settings.step_4_title != blank %}
        <div class="ai-usage-guide-step-{{ ai_gen_id }}">
          <div class="ai-usage-guide-step-number-{{ ai_gen_id }}">4</div>
          <h3 class="ai-usage-guide-step-title-{{ ai_gen_id }}">{{ block.settings.step_4_title }}</h3>
          <p class="ai-usage-guide-step-description-{{ ai_gen_id }}">{{ block.settings.step_4_description }}</p>
          <div class="ai-usage-guide-arrow-{{ ai_gen_id }}">→</div>
        </div>
      {% endif %}
    </div>

    <div class="ai-usage-guide-frequency-{{ ai_gen_id }}">
      {% if block.settings.frequency_title != blank %}
        <h3 class="ai-usage-guide-frequency-title-{{ ai_gen_id }}">{{ block.settings.frequency_title }}</h3>
      {% endif %}

      <div class="ai-usage-guide-frequency-grid-{{ ai_gen_id }}">
        {% if block.settings.frequency_1_label != blank %}
          <div class="ai-usage-guide-frequency-item-{{ ai_gen_id }}">
            <div class="ai-usage-guide-frequency-label-{{ ai_gen_id }}">{{ block.settings.frequency_1_label }}</div>
            <div class="ai-usage-guide-frequency-value-{{ ai_gen_id }}">{{ block.settings.frequency_1_value }}</div>
          </div>
        {% endif %}

        {% if block.settings.frequency_2_label != blank %}
          <div class="ai-usage-guide-frequency-item-{{ ai_gen_id }}">
            <div class="ai-usage-guide-frequency-label-{{ ai_gen_id }}">{{ block.settings.frequency_2_label }}</div>
            <div class="ai-usage-guide-frequency-value-{{ ai_gen_id }}">{{ block.settings.frequency_2_value }}</div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

