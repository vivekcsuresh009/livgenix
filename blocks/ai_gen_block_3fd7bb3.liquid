{% doc %}
  @prompt
    Redesign this section to create a stronger visual hierarchy while maintaining the premium LiveGenix aesthetic.
    
    Changes:
    
    • Replace the oversized logo with a premium lifestyle image showing LiveGenix products with natural Ayurvedic ingredients.
    
    • Keep a 50/50 split layout.
    
    • Add a small eyebrow text:
    OUR PHILOSOPHY
    
    • Replace the heading with:
    Hair Wellness Starts at the Root.
    
    • Increase the heading size and reduce the paragraph width for comfortable reading.
    
    • Add three feature points beneath the paragraph with premium gold icons:
    - Inspired by Ayurveda
    - Backed by Modern Science
    - Designed for Long-Term Hair Wellness
    
    • Add more whitespace between elements.
    
    • Vertically center the content.
    
    • Keep the background subtle with a soft cream gradient.
    
    • Maintain the existing typography, colors, and luxury aesthetic.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-philosophy-section-{{ ai_gen_id }} {
    width: 100%;
    background: linear-gradient(135deg, {{ block.settings.gradient_color_1 }} 0%, {{ block.settings.gradient_color_2 }} 100%);
    padding: {{ block.settings.section_padding_desktop }}px 0;
  }

  .ai-philosophy-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.column_gap }}px;
    align-items: center;
  }

  .ai-philosophy-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 500px;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-philosophy-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-philosophy-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-philosophy-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-philosophy-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 24px;
    background: rgba(255, 255, 255, 0.9);
    border-radius: 8px;
    font-size: 14px;
    color: #666;
    text-align: center;
  }

  .ai-philosophy-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_spacing }}px;
    padding: {{ block.settings.content_padding }}px;
  }

  .ai-philosophy-eyebrow-{{ ai_gen_id }} {
    font-family: {{ block.settings.eyebrow_font.family }}, {{ block.settings.eyebrow_font.fallback_families }};
    font-weight: {{ block.settings.eyebrow_font.weight }};
    font-size: {{ block.settings.eyebrow_size }}px;
    letter-spacing: {{ block.settings.eyebrow_letter_spacing }}px;
    text-transform: uppercase;
    color: {{ block.settings.eyebrow_color }};
    margin: 0;
  }

  .ai-philosophy-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: {{ block.settings.heading_line_height }};
    color: {{ block.settings.heading_color }};
    margin: 0;
  }

  .ai-philosophy-description-{{ ai_gen_id }} {
    font-family: {{ block.settings.description_font.family }}, {{ block.settings.description_font.fallback_families }};
    font-weight: {{ block.settings.description_font.weight }};
    font-size: {{ block.settings.description_size }}px;
    line-height: {{ block.settings.description_line_height }};
    color: {{ block.settings.description_color }};
    max-width: {{ block.settings.description_max_width }}%;
    margin: 0;
  }

  .ai-philosophy-features-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.feature_spacing }}px;
    margin-top: {{ block.settings.features_top_margin }}px;
  }

  .ai-philosophy-feature-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .ai-philosophy-feature-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.icon_background }};
    border-radius: 50%;
    padding: 8px;
  }

  .ai-philosophy-feature-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: {{ block.settings.icon_color }};
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ai-philosophy-feature-text-{{ ai_gen_id }} {
    font-family: {{ block.settings.feature_font.family }}, {{ block.settings.feature_font.fallback_families }};
    font-weight: {{ block.settings.feature_font.weight }};
    font-size: {{ block.settings.feature_size }}px;
    line-height: 1.5;
    color: {{ block.settings.feature_color }};
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-philosophy-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_mobile }}px 0;
    }

    .ai-philosophy-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 0 20px;
    }

    .ai-philosophy-image-wrapper-{{ ai_gen_id }} {
      min-height: 400px;
    }

    .ai-philosophy-content-{{ ai_gen_id }} {
      padding: 0;
    }

    .ai-philosophy-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-philosophy-description-{{ ai_gen_id }} {
      max-width: 100%;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-philosophy-image-wrapper-{{ ai_gen_id }} {
      min-height: 300px;
    }

    .ai-philosophy-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }

    .ai-philosophy-eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.eyebrow_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-philosophy-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-philosophy-container-{{ ai_gen_id }}">
    <div class="ai-philosophy-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.lifestyle_image %}
        <img
          src="{{ block.settings.lifestyle_image | image_url: width: 1200 }}"
          alt="{{ block.settings.lifestyle_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.lifestyle_image.width }}"
          height="{{ block.settings.lifestyle_image.height }}"
          class="ai-philosophy-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-philosophy-image-placeholder-{{ ai_gen_id }}">
          {{ 'lifestyle-1' | placeholder_svg_tag }}
          <div class="ai-philosophy-empty-state-{{ ai_gen_id }}">
            Add a premium lifestyle image showing LiveGenix products with natural Ayurvedic ingredients
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-philosophy-content-{{ ai_gen_id }}">
      {% if block.settings.eyebrow_text != blank %}
        <p class="ai-philosophy-eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow_text }}</p>
      {% endif %}

      {% if block.settings.heading != blank %}
        <h2 class="ai-philosophy-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.description != blank %}
        <div class="ai-philosophy-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
      {% endif %}

      <div class="ai-philosophy-features-{{ ai_gen_id }}">
        {% if block.settings.feature_1_text != blank %}
          <div class="ai-philosophy-feature-{{ ai_gen_id }}">
            <div class="ai-philosophy-feature-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                <path d="M2 17l10 5 10-5M2 12l10 5 10-5"/>
              </svg>
            </div>
            <p class="ai-philosophy-feature-text-{{ ai_gen_id }}">{{ block.settings.feature_1_text }}</p>
          </div>
        {% endif %}

        {% if block.settings.feature_2_text != blank %}
          <div class="ai-philosophy-feature-{{ ai_gen_id }}">
            <div class="ai-philosophy-feature-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 6v6l4 2"/>
              </svg>
            </div>
            <p class="ai-philosophy-feature-text-{{ ai_gen_id }}">{{ block.settings.feature_2_text }}</p>
          </div>
        {% endif %}

        {% if block.settings.feature_3_text != blank %}
          <div class="ai-philosophy-feature-{{ ai_gen_id }}">
            <div class="ai-philosophy-feature-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
            </div>
            <p class="ai-philosophy-feature-text-{{ ai_gen_id }}">{{ block.settings.feature_3_text }}</p>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

