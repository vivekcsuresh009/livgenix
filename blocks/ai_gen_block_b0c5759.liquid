{% doc %}
  @prompt
    Create a premium split-layout section similar to the attached reference.
    
    Layout:
    • Two equal columns (50/50).
    • Left: Large premium lifestyle/product image with rounded corners (20px).
    • Right: Content.
    • White background.
    • Generous spacing (100px top & bottom).
    • Responsive on mobile.
    
    Content:
    
    Eyebrow:
    PRODUCT PHILOSOPHY
    
    Heading:
    Hair Wellness Begins at the Root.
    
    Body:
    At LiveGenix, we believe healthier hair starts long before the first strand appears. Rather than masking symptoms, our formulations are designed to support scalp health, nourish from within, and promote long-term hair wellness.
    
    Inspired by the principles of Ayurveda and strengthened by modern scientific research, every product is created to work in harmony with your body's natural processes.
    
    We focus on consistency over quick fixes, helping you build healthier hair through thoughtful daily care.
    
    Button:
    Learn More
    
    Design:
    • Olive green heading
    • Premium typography
    • Gold accent line
    • Luxury minimalist aesthetic
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-split-layout-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }

  .ai-split-layout-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-split-layout-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.column_gap }}px;
    align-items: center;
  }

  .ai-split-layout-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
  }

  .ai-split-layout-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
    object-fit: cover;
  }

  .ai-split-layout-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 5;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-split-layout-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-split-layout-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-split-layout-content-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding }}px;
  }

  .ai-split-layout-eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_size }}px;
    color: {{ block.settings.eyebrow_color }};
    letter-spacing: {{ block.settings.eyebrow_letter_spacing }}px;
    text-transform: uppercase;
    margin-bottom: {{ block.settings.eyebrow_spacing }}px;
    font-weight: 500;
  }

  .ai-split-layout-accent-line-{{ ai_gen_id }} {
    width: {{ block.settings.accent_line_width }}px;
    height: {{ block.settings.accent_line_height }}px;
    background-color: {{ block.settings.accent_line_color }};
    margin-bottom: {{ block.settings.accent_line_spacing }}px;
  }

  .ai-split-layout-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    line-height: 1.2;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    font-weight: 700;
  }

  .ai-split-layout-body-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_size }}px;
    color: {{ block.settings.body_color }};
    line-height: 1.7;
    margin-bottom: {{ block.settings.body_spacing }}px;
  }

  .ai-split-layout-body-{{ ai_gen_id }} p {
    margin-bottom: 16px;
  }

  .ai-split-layout-body-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-split-layout-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 500;
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
  }

  .ai-split-layout-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-split-layout-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px 0 {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-split-layout-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.column_gap_mobile }}px;
    }

    {% if block.settings.mobile_layout == 'image_first' %}
      .ai-split-layout-image-wrapper-{{ ai_gen_id }} {
        order: 1;
      }
      .ai-split-layout-content-{{ ai_gen_id }} {
        order: 2;
      }
    {% else %}
      .ai-split-layout-image-wrapper-{{ ai_gen_id }} {
        order: 2;
      }
      .ai-split-layout-content-{{ ai_gen_id }} {
        order: 1;
      }
    {% endif %}

    .ai-split-layout-content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding_mobile }}px;
    }

    .ai-split-layout-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-split-layout-body-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-split-layout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-split-layout-container-{{ ai_gen_id }}">
    <div class="ai-split-layout-grid-{{ ai_gen_id }}">
      <div class="ai-split-layout-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 1200 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            class="ai-split-layout-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-split-layout-image-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
            <div class="ai-split-layout-empty-state-{{ ai_gen_id }}">
              Add a lifestyle or product image
            </div>
          </div>
        {% endif %}
      </div>

      <div class="ai-split-layout-content-{{ ai_gen_id }}">
        {% if block.settings.show_eyebrow and block.settings.eyebrow != blank %}
          <div class="ai-split-layout-eyebrow-{{ ai_gen_id }}">
            {{ block.settings.eyebrow }}
          </div>
        {% endif %}

        {% if block.settings.show_accent_line %}
          <div class="ai-split-layout-accent-line-{{ ai_gen_id }}"></div>
        {% endif %}

        {% if block.settings.heading != blank %}
          <h2 class="ai-split-layout-heading-{{ ai_gen_id }}">
            {{ block.settings.heading }}
          </h2>
        {% endif %}

        {% if block.settings.body != blank %}
          <div class="ai-split-layout-body-{{ ai_gen_id }}">
            {{ block.settings.body }}
          </div>
        {% endif %}

        {% if block.settings.show_button and block.settings.button_text != blank %}
          <a
            href="{{ block.settings.button_link }}"
            class="ai-split-layout-button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

