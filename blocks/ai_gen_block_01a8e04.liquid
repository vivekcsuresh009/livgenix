{% doc %}
  @prompt
    Create a premium "Business Information & Grievance Officer" section for a luxury
    Ayurvedic hair wellness brand called Livgenix.

    Redesigned per brand design system: refined two-column luxury cards, subtle low-opacity
    botanical watermark as the "branded visual" backdrop, soft cream section background,
    hover elevation on cards, CSS custom properties, prefers-reduced-motion support.
    Preserves all business/compliance content exactly as before.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-business-info-{{ ai_gen_id }} {
    --lg-heading: {{ block.settings.heading_color }};
    --lg-gold: {{ block.settings.accent_color }};
    --lg-text: {{ block.settings.text_color }};
    --lg-label: {{ block.settings.label_color }};
    --lg-card-bg: {{ block.settings.card_background }};
    --lg-card-border: {{ block.settings.card_border_color }};
    --lg-note-bg: {{ block.settings.note_background }};
    --lg-timeline-bg: {{ block.settings.timeline_background }};
    --lg-radius-card: {{ block.settings.card_border_radius }}px;

    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_mobile }}px 20px;
    position: relative;
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .ai-business-info-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_desktop }}px 40px;
    }
  }

  .ai-business-info-watermark-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    right: -6%;
    width: 480px;
    height: 480px;
    transform: translateY(-50%);
    stroke: var(--lg-heading);
    fill: none;
    stroke-width: 1;
    opacity: 0.035;
    pointer-events: none;
  }

  .ai-business-info-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    position: relative;
  }

  .ai-business-info-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  @media screen and (min-width: 990px) {
    .ai-business-info-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr 1fr;
      gap: 48px;
    }
  }

  .ai-business-info-column-{{ ai_gen_id }} {
    opacity: 0;
    transform: translateY(30px);
    animation: ai-business-info-fade-up-{{ ai_gen_id }} 0.8s ease-out forwards;
  }

  .ai-business-info-column-{{ ai_gen_id }}:nth-child(2) {
    animation-delay: 0.2s;
  }

  @keyframes ai-business-info-fade-up-{{ ai_gen_id }} {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-business-info-column-{{ ai_gen_id }} {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  .ai-business-info-eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_size }}px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--lg-gold);
    margin-bottom: 12px;
  }

  .ai-business-info-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size_mobile }}px;
    font-weight: 700;
    color: var(--lg-heading);
    margin: 0 0 24px 0;
    line-height: 1.2;
  }

  @media screen and (min-width: 750px) {
    .ai-business-info-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size }}px;
    }
  }

  .ai-business-info-card-{{ ai_gen_id }} {
    background-color: var(--lg-card-bg);
    border: 1px solid var(--lg-card-border);
    border-radius: var(--lg-radius-card);
    padding: 32px 24px;
    box-shadow: 0 2px 16px rgba(47, 51, 36, 0.04);
    transition: transform 300ms ease, box-shadow 300ms ease;
  }

  .ai-business-info-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 36px rgba(47, 51, 36, 0.08);
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-business-info-card-{{ ai_gen_id }} {
      transition: none;
    }
  }

  @media screen and (min-width: 750px) {
    .ai-business-info-card-{{ ai_gen_id }} {
      padding: 40px 32px;
    }
  }

  .ai-business-info-item-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 24px;
  }

  .ai-business-info-item-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-business-info-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: rgba(190, 154, 92, 0.1);
  }

  .ai-business-info-icon-{{ ai_gen_id }} svg {
    width: 18px;
    height: 18px;
    stroke: var(--lg-gold);
    fill: none;
    stroke-width: 1.75;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ai-business-info-content-{{ ai_gen_id }} {
    flex-grow: 1;
    padding-top: 2px;
  }

  .ai-business-info-label-{{ ai_gen_id }} {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--lg-label);
    margin-bottom: 4px;
  }

  .ai-business-info-value-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    color: var(--lg-text);
    margin: 0;
    white-space: pre-line;
  }

  .ai-business-info-note-{{ ai_gen_id }} {
    margin-top: 24px;
    padding: 20px;
    background-color: var(--lg-note-bg);
    border-radius: 14px;
    font-size: {{ block.settings.note_text_size }}px;
    line-height: 1.6;
    color: var(--lg-text);
    font-style: italic;
  }

  .ai-business-info-timeline-{{ ai_gen_id }} {
    margin-top: 16px;
    padding: 16px;
    background-color: var(--lg-timeline-bg);
    border-radius: 10px;
    font-size: {{ block.settings.note_text_size }}px;
    color: var(--lg-text);
  }
{% endstyle %}

