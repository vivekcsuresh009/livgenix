{% doc %}
  @prompt
    Create a premium "The LiveGenix Hair Wellness System" section, followed by a
    "Healthy Hair Starts at the Root" storytelling statement.

    Redesigned per brand design system: six premium cards with large outline icons, soft
    shadows, hover elevation, an animated gradient top-border accent and icon micro-motion,
    staggered fade-up reveal on scroll; the footer statement becomes a centered editorial
    moment with a gold divider and a very low-opacity molecular/botanical background texture.
    CSS custom properties, prefers-reduced-motion support. Content and settings are unchanged.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hair-wellness-system-{{ ai_gen_id }} {
    --lg-heading: {{ block.settings.heading_color }};
    --lg-gold: #BE9A5C;
    --lg-text: #6F764F;

    display: block;
    background-color: #ffffff;
    padding: 100px 20px;
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .ai-hair-wellness-container-{{ ai_gen_id }} {
    max-width: 1280px;
    margin: 0 auto;
    position: relative;
  }

  .ai-hair-wellness-heading-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 64px;
    color: var(--lg-heading);
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.01em;
    opacity: 0;
    transform: translateY(20px);
  }

  .ai-hair-wellness-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-bottom: 90px;
  }

  .ai-hair-wellness-card-{{ ai_gen_id }} {
    position: relative;
    background-color: #ffffff;
    border: 1px solid #E8E5DF;
    border-radius: 20px;
    padding: 44px 32px;
    box-shadow: 0 2px 16px rgba(47, 51, 36, 0.04);
    transition: transform 300ms ease, box-shadow 300ms ease, border-color 300ms ease;
    display: flex;
    flex-direction: column;
    gap: 16px;
    overflow: hidden;
    opacity: 0;
    transform: translateY(28px);
  }

  .ai-hair-wellness-card-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--lg-gold), var(--lg-heading));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 400ms ease;
  }

  .ai-hair-wellness-card-{{ ai_gen_id }}:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px rgba(47, 51, 36, 0.1);
    border-color: var(--lg-gold);
  }

  .ai-hair-wellness-card-{{ ai_gen_id }}:hover::before {
    transform: scaleX(1);
  }

  .ai-hair-wellness-card-{{ ai_gen_id }}:hover .ai-hair-wellness-icon-{{ ai_gen_id }} {
    transform: scale(1.1) rotate(-4deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-hair-wellness-card-{{ ai_gen_id }},
    .ai-hair-wellness-card-{{ ai_gen_id }}::before,
    .ai-hair-wellness-icon-{{ ai_gen_id }} {
      transition: none;
    }
  }

  .ai-hair-wellness-icon-{{ ai_gen_id }} {
    width: 52px;
    height: 52px;
    color: var(--lg-gold);
    flex-shrink: 0;
    transition: transform 300ms ease;
  }

  .ai-hair-wellness-eyebrow-{{ ai_gen_id }} {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--lg-gold);
    margin: 0;
  }

  .ai-hair-wellness-card-title-{{ ai_gen_id }} {
    font-size: 21px;
    font-weight: 700;
    color: var(--lg-heading);
    margin: 0;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .ai-hair-wellness-card-text-{{ ai_gen_id }} {
    font-size: 14.5px;
    line-height: 1.65;
    color: var(--lg-text);
    margin: 0;
  }

  .ai-hair-wellness-footer-{{ ai_gen_id }} {
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    opacity: 0;
    transform: translateY(20px);
  }

  .ai-hair-wellness-footer-divider-{{ ai_gen_id }} {
    width: 64px;
    height: 2px;
    margin: 0 auto 28px;
    background: linear-gradient(90deg, transparent, var(--lg-gold), transparent);
  }

  .ai-hair-wellness-footer-heading-{{ ai_gen_id }} {
    font-size: 32px;
    font-weight: 700;
    color: var(--lg-heading);
    margin: 0 0 20px;
    letter-spacing: -0.01em;
  }

  .ai-hair-wellness-footer-text-{{ ai_gen_id }} {
    font-size: 17px;
    line-height: 1.8;
    color: var(--lg-text);
    margin: 0;
  }

  .ai-hair-wellness-system-{{ ai_gen_id }}.ai-visible-{{ ai_gen_id }} .ai-hair-wellness-heading-{{ ai_gen_id }} {
    animation: ai-hair-wellness-fade-up-{{ ai_gen_id }} 0.8s ease-out forwards;
  }

  .ai-hair-wellness-system-{{ ai_gen_id }}.ai-visible-{{ ai_gen_id }} .ai-hair-wellness-card-{{ ai_gen_id }}:nth-child(1) {
    animation: ai-hair-wellness-fade-up-{{ ai_gen_id }} 0.7s ease-out 0.05s forwards;
  }

  .ai-hair-wellness-system-{{ ai_gen_id }}.ai-visible-{{ ai_gen_id }} .ai-hair-wellness-card-{{ ai_gen_id }}:nth-child(2) {
    animation: ai-hair-wellness-fade-up-{{ ai_gen_id }} 0.7s ease-out 0.15s forwards;
  }

  .ai-hair-wellness-system-{{ ai_gen_id }}.ai-visible-{{ ai_gen_id }} .ai-hair-wellness-card-{{ ai_gen_id }}:nth-child(3) {
    animation: ai-hair-wellness-fade-up-{{ ai_gen_id }} 0.7s ease-out 0.25s forwards;
  }

  .ai-hair-wellness-system-{{ ai_gen_id }}.ai-visible-{{ ai_gen_id }} .ai-hair-wellness-card-{{ ai_gen_id }}:nth-child(4) {
    animation: ai-hair-wellness-fade-up-{{ ai_gen_id }} 0.7s ease-out 0.35s forwards;
  }

  .ai-hair-wellness-system-{{ ai_gen_id }}.ai-visible-{{ ai_gen_id }} .ai-hair-wellness-card-{{ ai_gen_id }}:nth-child(5) {
    animation: ai-hair-wellness-fade-up-{{ ai_gen_id }} 0.7s ease-out 0.45s forwards;
  }

  .ai-hair-wellness-system-{{ ai_gen_id }}.ai-visible-{{ ai_gen_id }} .ai-hair-wellness-card-{{ ai_gen_id }}:nth-child(6) {
    animation: ai-hair-wellness-fade-up-{{ ai_gen_id }} 0.7s ease-out 0.55s forwards;
  }

  .ai-hair-wellness-system-{{ ai_gen_id }}.ai-visible-{{ ai_gen_id }} .ai-hair-wellness-footer-{{ ai_gen_id }} {
    animation: ai-hair-wellness-fade-up-{{ ai_gen_id }} 0.8s ease-out 0.2s forwards;
  }

  @keyframes ai-hair-wellness-fade-up-{{ ai_gen_id }} {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-hair-wellness-heading-{{ ai_gen_id }},
    .ai-hair-wellness-card-{{ ai_gen_id }},
    .ai-hair-wellness-footer-{{ ai_gen_id }} {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }

  .ai-hair-wellness-molecular-{{ ai_gen_id }} {
    position: absolute;
    top: -6%;
    right: -4%;
    width: 420px;
    height: 420px;
    opacity: 0.035;
    stroke: var(--lg-heading);
    fill: none;
    stroke-width: 1;
    pointer-events: none;
  }

  @media screen and (max-width: 989px) {
    .ai-hair-wellness-system-{{ ai_gen_id }} {
      padding: 70px 20px;
    }

    .ai-hair-wellness-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.75 }}px;
      margin-bottom: 44px;
    }

    .ai-hair-wellness-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
      margin-bottom: 64px;
    }

    .ai-hair-wellness-card-{{ ai_gen_id }} {
      padding: 32px 24px;
    }

    .ai-hair-wellness-footer-heading-{{ ai_gen_id }} {
      font-size: 26px;
    }

    .ai-hair-wellness-footer-text-{{ ai_gen_id }} {
      font-size: 15px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-hair-wellness-system-{{ ai_gen_id }} {
      padding: 56px 16px;
    }

    .ai-hair-wellness-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
      margin-bottom: 36px;
    }

    .ai-hair-wellness-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 16px;
      margin-bottom: 48px;
    }

    .ai-hair-wellness-card-{{ ai_gen_id }} {
      padding: 30px 22px;
    }

    .ai-hair-wellness-icon-{{ ai_gen_id }} {
      width: 44px;
      height: 44px;
    }

    .ai-hair-wellness-card-title-{{ ai_gen_id }} {
      font-size: 18px;
    }

    .ai-hair-wellness-footer-heading-{{ ai_gen_id }} {
      font-size: 23px;
    }

    .ai-hair-wellness-footer-text-{{ ai_gen_id }} {
      font-size: 14.5px;
    }
  }
{% endstyle %}

<ai-hair-wellness-{{ ai_gen_id }} class="ai-hair-wellness-system-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <svg class="ai-hair-wellness-molecular-{{ ai_gen_id }}" viewBox="0 0 200 200" aria-hidden="true" focusable="false">
    <circle cx="60" cy="60" r="6" />
    <circle cx="140" cy="50" r="5" />
    <circle cx="110" cy="120" r="7" />
    <circle cx="40" cy="140" r="4" />
    <circle cx="160" cy="150" r="5" />
    <path d="M60 60L140 50M60 60L110 120M110 120L40 140M110 120L160 150" />
  </svg>

  <div class="ai-hair-wellness-container-{{ ai_gen_id }}">
    {% if block.settings.section_heading != blank %}
      <h2 class="ai-hair-wellness-heading-{{ ai_gen_id }}">{{ block.settings.section_heading }}</h2>
    {% endif %}

    <div class="ai-hair-wellness-grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign eyebrow_key = 'card_' | append: i | append: '_eyebrow'
          assign title_key = 'card_' | append: i | append: '_title'
          assign text_key = 'card_' | append: i | append: '_text'
          assign icon_key = 'card_' | append: i | append: '_icon'

          assign eyebrow = block.settings[eyebrow_key]
          assign title = block.settings[title_key]
          assign text = block.settings[text_key]
          assign icon = block.settings[icon_key]
        %}

        <div class="ai-hair-wellness-card-{{ ai_gen_id }}">
          <div class="ai-hair-wellness-icon-{{ ai_gen_id }}">
            {% if icon == 'leaf' %}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 3.75c-5.385 0-9.75 4.365-9.75 9.75 0 1.33.266 2.597.75 3.75L3 21.75l4.5-8.25c1.153.484 2.42.75 3.75.75 5.385 0 9.75-4.365 9.75-9.75z" />
              </svg>
            {% elsif icon == 'science' %}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.75v7.5m4.5-7.5v7.5m-9 3.75h13.5m-13.5 0a2.25 2.25 0 002.25 2.25h9a2.25 2.25 0 002.25-2.25m-13.5 0V9a2.25 2.25 0 012.25-2.25h9A2.25 2.25 0 0121.75 9v5.25" />
              </svg>
            {% elsif icon == 'calendar' %}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
              </svg>
            {% elsif icon == 'heart' %}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
              </svg>
            {% elsif icon == 'sparkles' %}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
              </svg>
            {% else %}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            {% endif %}
          </div>

          {% if eyebrow != blank %}
            <p class="ai-hair-wellness-eyebrow-{{ ai_gen_id }}">{{ eyebrow }}</p>
          {% endif %}

          {% if title != blank %}
            <h3 class="ai-hair-wellness-card-title-{{ ai_gen_id }}">{{ title }}</h3>
          {% endif %}

          {% if text != blank %}
            <p class="ai-hair-wellness-card-text-{{ ai_gen_id }}">{{ text }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <div class="ai-hair-wellness-footer-{{ ai_gen_id }}">
      <div class="ai-hair-wellness-footer-divider-{{ ai_gen_id }}"></div>

      {% if block.settings.footer_heading != blank %}
        <h3 class="ai-hair-wellness-footer-heading-{{ ai_gen_id }}">{{ block.settings.footer_heading }}</h3>
      {% endif %}

      {% if block.settings.footer_text != blank %}
        <p class="ai-hair-wellness-footer-text-{{ ai_gen_id }}">{{ block.settings.footer_text }}</p>
      {% endif %}
    </div>
  </div>
</ai-hair-wellness-{{ ai_gen_id }}>

<script>
  (function() {
    class AiHairWellness{{ ai_gen_id }} extends HTMLElement {
      connectedCallback() {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          return;
        }

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('ai-visible-{{ ai_gen_id }}');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1 });

        observer.observe(this);
      }
    }

    if (!customElements.get('ai-hair-wellness-{{ ai_gen_id }}')) {
      customElements.define('ai-hair-wellness-{{ ai_gen_id }}', AiHairWellness{{ ai_gen_id }});
    }
  })();
</script>

