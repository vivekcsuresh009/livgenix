{% doc %}
  @prompt
    Create a premium "The LiveGenix Hair Wellness System" section.
    
    Layout:
    - White background.
    - Centered section heading.
    - Five equal cards in a responsive grid (3 on top, 2 below on desktop, stacked on mobile).
    - Each card contains:
      • Premium gold line icon
      • Small eyebrow text
      • Bold title
      • 2–3 lines of supporting text
    - Add subtle rounded corners (16px), light borders (#E8E5DF), and generous whitespace.
    - Hover effect: slight elevation and border color change to Premium Gold (#BE9A5C).
    - Below the cards, add a centered statement:
      "Healthy Hair Starts at the Root"
      followed by a short paragraph explaining that LiveGenix combines Ayurveda, science, and consistent daily care for long-term hair wellness.
    - Maintain the existing LiveGenix typography, spacing, and premium luxury aesthetic.
    - Fully responsive for desktop, tablet, and mobile., create 6 boxes instead of 5
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hair-wellness-system-{{ ai_gen_id }} {
    display: block;
    background-color: #ffffff;
    padding: 80px 20px;
    width: 100%;
  }

  .ai-hair-wellness-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-hair-wellness-heading-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 60px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
  }

  .ai-hair-wellness-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 60px;
  }

  .ai-hair-wellness-card-{{ ai_gen_id }} {
    background-color: #ffffff;
    border: 1px solid #E8E5DF;
    border-radius: 16px;
    padding: 40px 32px;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-hair-wellness-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    border-color: #BE9A5C;
  }

  .ai-hair-wellness-icon-{{ ai_gen_id }} {
    width: 48px;
    height: 48px;
    color: #BE9A5C;
    flex-shrink: 0;
  }

  .ai-hair-wellness-eyebrow-{{ ai_gen_id }} {
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #BE9A5C;
    margin: 0;
  }

  .ai-hair-wellness-card-title-{{ ai_gen_id }} {
    font-size: 20px;
    font-weight: 700;
    color: #2F3324;
    margin: 0;
    line-height: 1.3;
  }

  .ai-hair-wellness-card-text-{{ ai_gen_id }} {
    font-size: 14px;
    line-height: 1.6;
    color: #6F764F;
    margin: 0;
  }

  .ai-hair-wellness-footer-{{ ai_gen_id }} {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .ai-hair-wellness-footer-heading-{{ ai_gen_id }} {
    font-size: 28px;
    font-weight: 700;
    color: #2F3324;
    margin: 0 0 16px;
  }

  .ai-hair-wellness-footer-text-{{ ai_gen_id }} {
    font-size: 16px;
    line-height: 1.7;
    color: #6F764F;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-hair-wellness-system-{{ ai_gen_id }} {
      padding: 60px 20px;
    }

    .ai-hair-wellness-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.75 }}px;
      margin-bottom: 40px;
    }

    .ai-hair-wellness-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
      margin-bottom: 50px;
    }

    .ai-hair-wellness-card-{{ ai_gen_id }} {
      padding: 32px 24px;
    }

    .ai-hair-wellness-footer-heading-{{ ai_gen_id }} {
      font-size: 24px;
    }

    .ai-hair-wellness-footer-text-{{ ai_gen_id }} {
      font-size: 15px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-hair-wellness-system-{{ ai_gen_id }} {
      padding: 50px 16px;
    }

    .ai-hair-wellness-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
      margin-bottom: 32px;
    }

    .ai-hair-wellness-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 16px;
      margin-bottom: 40px;
    }

    .ai-hair-wellness-card-{{ ai_gen_id }} {
      padding: 28px 20px;
    }

    .ai-hair-wellness-icon-{{ ai_gen_id }} {
      width: 40px;
      height: 40px;
    }

    .ai-hair-wellness-card-title-{{ ai_gen_id }} {
      font-size: 18px;
    }

    .ai-hair-wellness-footer-heading-{{ ai_gen_id }} {
      font-size: 22px;
    }

    .ai-hair-wellness-footer-text-{{ ai_gen_id }} {
      font-size: 14px;
    }
  }
{% endstyle %}

<div class="ai-hair-wellness-system-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hair-wellness-container-{{ ai_gen_id }}">
    {% if block.settings.section_heading != blank %}
      <h2 class="ai-hair-wellness-heading-{{ ai_gen_id }}">{{ block.settings.section_heading }}</h2>
    {% endif %}

    <div class="ai-hair-wellness-grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign eyebrow_key = 'card_' | append: i | append: '_eyebrow'
          assign title_key = 'card_' | append: i | append: '_title'
          assign text_key = 'card_' | append: i | append: '_text'
          assign icon_key = 'card_' | append: i | append: '_icon'

          assign eyebrow = block.settings[eyebrow_key]
          assign title = block.settings[title_key]
          assign text = block.settings[text_key]
          assign icon = block.settings[icon_key]
        %}

        <div class="ai-hair-wellness-card-{{ ai_gen_id }}">
          <div class="ai-hair-wellness-icon-{{ ai_gen_id }}">
            {% if icon == 'leaf' %}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 3.75c-5.385 0-9.75 4.365-9.75 9.75 0 1.33.266 2.597.75 3.75L3 21.75l4.5-8.25c1.153.484 2.42.75 3.75.75 5.385 0 9.75-4.365 9.75-9.75z" />
              </svg>
            {% elsif icon == 'science' %}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.75v7.5m4.5-7.5v7.5m-9 3.75h13.5m-13.5 0a2.25 2.25 0 002.25 2.25h9a2.25 2.25 0 002.25-2.25m-13.5 0V9a2.25 2.25 0 012.25-2.25h9A2.25 2.25 0 0121.75 9v5.25" />
              </svg>
            {% elsif icon == 'calendar' %}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
              </svg>
            {% elsif icon == 'heart' %}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
              </svg>
            {% elsif icon == 'sparkles' %}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
              </svg>
            {% else %}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            {% endif %}
          </div>

          {% if eyebrow != blank %}
            <p class="ai-hair-wellness-eyebrow-{{ ai_gen_id }}">{{ eyebrow }}</p>
          {% endif %}

          {% if title != blank %}
            <h3 class="ai-hair-wellness-card-title-{{ ai_gen_id }}">{{ title }}</h3>
          {% endif %}

          {% if text != blank %}
            <p class="ai-hair-wellness-card-text-{{ ai_gen_id }}">{{ text }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <div class="ai-hair-wellness-footer-{{ ai_gen_id }}">
      {% if block.settings.footer_heading != blank %}
        <h3 class="ai-hair-wellness-footer-heading-{{ ai_gen_id }}">{{ block.settings.footer_heading }}</h3>
      {% endif %}

      {% if block.settings.footer_text != blank %}
        <p class="ai-hair-wellness-footer-text-{{ ai_gen_id }}">{{ block.settings.footer_text }}</p>
      {% endif %}
    </div>
  </div>
</div>

