{% doc %}
  @prompt
    Create a six-card benefits section.
    
    Headline:
    Why You'll Love Coconeela
    
    Include these benefits:
    
    • Nourishes the Scalp
    • Supports Healthy Hair Roots
    • Maintains Scalp Hydration
    • Reduces Dryness & Flaking
    • Improves Hair Manageability
    • Enhances Natural Shine
    
    Each card should include:
    • Premium line icon
    • Title
    • Short supporting description
    
    Style:
    Minimal, premium Ayurvedic, rounded cards with subtle hover effects.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-benefits-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-benefits-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-benefits-heading-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
  }

  .ai-benefits-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: {{ block.settings.card_gap }}px;
  }

  .ai-benefit-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-benefit-card-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
    box-shadow: 0 {{ block.settings.hover_shadow_y }}px {{ block.settings.hover_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.hover_shadow_opacity }});
  }

  .ai-benefit-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto {{ block.settings.icon_spacing }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-benefit-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.icon_color }};
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ai-benefit-title-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.title_spacing }}px;
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
  }

  .ai-benefit-description-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.description_color }};
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.6;
  }

  @media screen and (max-width: 749px) {
    .ai-benefits-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: {{ block.settings.card_gap | times: 0.75 }}px;
    }

    .ai-benefits-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.75 }}px;
    }

    .ai-benefit-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.8 }}px;
    }
  }
{% endstyle %}

<benefits-section-{{ ai_gen_id }} class="ai-benefits-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-benefits-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-benefits-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-benefits-grid-{{ ai_gen_id }}">
      {% if block.settings.benefit_1_enabled %}
        <div class="ai-benefit-card-{{ ai_gen_id }}">
          <div class="ai-benefit-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
              <path d="M12 6v6l4 2"/>
            </svg>
          </div>
          <h3 class="ai-benefit-title-{{ ai_gen_id }}">{{ block.settings.benefit_1_title }}</h3>
          <p class="ai-benefit-description-{{ ai_gen_id }}">{{ block.settings.benefit_1_description }}</p>
        </div>
      {% endif %}

      {% if block.settings.benefit_2_enabled %}
        <div class="ai-benefit-card-{{ ai_gen_id }}">
          <div class="ai-benefit-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5M2 12l10 5 10-5"/>
            </svg>
          </div>
          <h3 class="ai-benefit-title-{{ ai_gen_id }}">{{ block.settings.benefit_2_title }}</h3>
          <p class="ai-benefit-description-{{ ai_gen_id }}">{{ block.settings.benefit_2_description }}</p>
        </div>
      {% endif %}

      {% if block.settings.benefit_3_enabled %}
        <div class="ai-benefit-card-{{ ai_gen_id }}">
          <div class="ai-benefit-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </div>
          <h3 class="ai-benefit-title-{{ ai_gen_id }}">{{ block.settings.benefit_3_title }}</h3>
          <p class="ai-benefit-description-{{ ai_gen_id }}">{{ block.settings.benefit_3_description }}</p>
        </div>
      {% endif %}

      {% if block.settings.benefit_4_enabled %}
        <div class="ai-benefit-card-{{ ai_gen_id }}">
          <div class="ai-benefit-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
              <polyline points="7.5 4.21 12 6.81 16.5 4.21"/>
              <polyline points="7.5 19.79 7.5 14.6 3 12"/>
              <polyline points="21 12 16.5 14.6 16.5 19.79"/>
              <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
              <line x1="12" y1="22.08" x2="12" y2="12"/>
            </svg>
          </div>
          <h3 class="ai-benefit-title-{{ ai_gen_id }}">{{ block.settings.benefit_4_title }}</h3>
          <p class="ai-benefit-description-{{ ai_gen_id }}">{{ block.settings.benefit_4_description }}</p>
        </div>
      {% endif %}

      {% if block.settings.benefit_5_enabled %}
        <div class="ai-benefit-card-{{ ai_gen_id }}">
          <div class="ai-benefit-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
            </svg>
          </div>
          <h3 class="ai-benefit-title-{{ ai_gen_id }}">{{ block.settings.benefit_5_title }}</h3>
          <p class="ai-benefit-description-{{ ai_gen_id }}">{{ block.settings.benefit_5_description }}</p>
        </div>
      {% endif %}

      {% if block.settings.benefit_6_enabled %}
        <div class="ai-benefit-card-{{ ai_gen_id }}">
          <div class="ai-benefit-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
          </div>
          <h3 class="ai-benefit-title-{{ ai_gen_id }}">{{ block.settings.benefit_6_title }}</h3>
          <p class="ai-benefit-description-{{ ai_gen_id }}">{{ block.settings.benefit_6_description }}</p>
        </div>
      {% endif %}
    </div>
  </div>
</benefits-section-{{ ai_gen_id }}>

