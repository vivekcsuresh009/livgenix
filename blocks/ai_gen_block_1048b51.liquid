{% doc %}
  @prompt
    Create a premium split-layout storytelling section explaining the meaning of the
    LiveGenix brand name.

    Redesigned per brand design system to be one of the most memorable sections on the
    page: left column becomes editorial storytelling with quote styling and a gold divider;
    right column becomes a glassmorphism card with an animated connecting line drawing
    downward between "Life", "+", "Genesis", "↓" and "LiveGenix" as the section scrolls into
    view, plus subtle hover effects on each label. CSS custom properties,
    prefers-reduced-motion support. Content and settings are unchanged.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-story-section-{{ ai_gen_id }} {
    --lg-heading: {{ block.settings.heading_color }};
    --lg-gold: {{ block.settings.accent_color }};
    --lg-sub: {{ block.settings.subheading_color }};
    --lg-text: {{ block.settings.body_color }};

    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-story-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.column_gap }}px;
    align-items: start;
  }

  .ai-story-left-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_spacing }}px;
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 800ms ease, transform 800ms ease;
  }

  .ai-story-section-{{ ai_gen_id }}.ai-visible-{{ ai_gen_id }} .ai-story-left-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-story-eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_size }}px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--lg-gold);
    margin: 0;
  }

  .ai-story-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--lg-heading);
    margin: 0;
  }

  .ai-story-divider-{{ ai_gen_id }} {
    width: 72px;
    height: 2px;
    background: linear-gradient(90deg, var(--lg-gold), transparent);
  }

  .ai-story-subheading-{{ ai_gen_id }} {
    position: relative;
    font-size: {{ block.settings.subheading_size }}px;
    font-weight: 500;
    font-style: italic;
    line-height: 1.5;
    color: var(--lg-sub);
    margin: 0;
    padding-left: 22px;
    border-left: 2px solid var(--lg-gold);
  }

  .ai-story-body-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_size }}px;
    line-height: 1.8;
    color: var(--lg-text);
  }

  .ai-story-body-{{ ai_gen_id }} p {
    margin: 0 0 {{ block.settings.paragraph_spacing }}px;
  }

  .ai-story-body-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-story-right-{{ ai_gen_id }} {
    position: sticky;
    top: 40px;
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 800ms ease 150ms, transform 800ms ease 150ms;
  }

  .ai-story-section-{{ ai_gen_id }}.ai-visible-{{ ai_gen_id }} .ai-story-right-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-story-left-{{ ai_gen_id }},
    .ai-story-right-{{ ai_gen_id }} {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  .ai-story-card-{{ ai_gen_id }} {
    position: relative;
    background-color: rgba(255, 255, 255, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.8);
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.card_spacing }}px;
    backdrop-filter: blur(14px);
    box-shadow: 0 24px 60px rgba(47, 51, 36, 0.1);
  }

  .ai-story-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-align: center;
    color: var(--lg-gold);
    margin: 0;
  }

  .ai-story-connector-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.card_spacing }}px;
  }

  .ai-story-connector-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 8px;
    bottom: 8px;
    left: 50%;
    width: 2px;
    background: linear-gradient(180deg, var(--lg-gold), {{ block.settings.heading_color }});
    transform: translateX(-50%) scaleY(0);
    transform-origin: top;
    transition: transform 1200ms ease;
    z-index: 0;
  }

  .ai-story-section-{{ ai_gen_id }}.ai-visible-{{ ai_gen_id }} .ai-story-connector-{{ ai_gen_id }}::before {
    transform: translateX(-50%) scaleY(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-story-connector-{{ ai_gen_id }}::before {
      transition: none;
      transform: translateX(-50%) scaleY(1);
    }
  }

  .ai-story-card-section-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 14px 18px;
    border-radius: 14px;
    background-color: rgba(255, 255, 255, 0.6);
    transition: transform 300ms ease, background-color 300ms ease;
  }

  .ai-story-card-section-{{ ai_gen_id }}:hover {
    transform: translateY(-3px);
    background-color: rgba(255, 255, 255, 0.9);
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-story-card-section-{{ ai_gen_id }} {
      transition: none;
    }
  }

  .ai-story-card-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_label_size }}px;
    font-weight: 700;
    color: var(--lg-heading);
    margin: 0;
    text-align: center;
  }

  .ai-story-card-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_text_size }}px;
    line-height: 1.6;
    color: var(--lg-text);
    margin: 0;
    text-align: center;
  }

  .ai-story-card-divider-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
    text-align: center;
    font-size: {{ block.settings.card_divider_size }}px;
    font-weight: 700;
    color: var(--lg-gold);
    margin: 0;
  }

  .ai-story-card-brand-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_brand_size }}px;
    font-weight: 700;
    text-align: center;
    color: var(--lg-heading);
    margin: 0;
  }

  .ai-story-card-arrow-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
    text-align: center;
    font-size: {{ block.settings.card_arrow_size }}px;
    color: var(--lg-gold);
    margin: 0;
  }

  .ai-story-card-tagline-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_tagline_size }}px;
    line-height: 1.5;
    text-align: center;
    color: var(--lg-text);
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-story-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_gap }}px;
    }

    .ai-story-right-{{ ai_gen_id }} {
      position: static;
    }

    .ai-story-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.75 }}px;
    }

    .ai-story-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.85 }}px;
    }

    .ai-story-card-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_title_size | times: 0.85 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-story-section-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_padding_top }}px {{ block.settings.mobile_padding_horizontal }}px {{ block.settings.mobile_padding_bottom }}px;
    }

    .ai-story-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }

    .ai-story-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.75 }}px;
    }
  }
{% endstyle %}

<ai-story-section-{{ ai_gen_id }} class="ai-story-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-story-container-{{ ai_gen_id }}">
    <div class="ai-story-left-{{ ai_gen_id }}">
      {% if block.settings.eyebrow != blank %}
        <p class="ai-story-eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow }}</p>
      {% endif %}

      {% if block.settings.heading != blank %}
        <h2 class="ai-story-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      <div class="ai-story-divider-{{ ai_gen_id }}"></div>

      {% if block.settings.subheading != blank %}
        <p class="ai-story-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
      {% endif %}

      {% if block.settings.body != blank %}
        <div class="ai-story-body-{{ ai_gen_id }}">
          {{ block.settings.body }}
        </div>
      {% endif %}
    </div>

    <div class="ai-story-right-{{ ai_gen_id }}">
      <div class="ai-story-card-{{ ai_gen_id }}">
        {% if block.settings.card_title != blank %}
          <h3 class="ai-story-card-title-{{ ai_gen_id }}">{{ block.settings.card_title }}</h3>
        {% endif %}

        <div class="ai-story-connector-{{ ai_gen_id }}">
          <div class="ai-story-card-section-{{ ai_gen_id }}">
            {% if block.settings.card_label_1 != blank %}
              <p class="ai-story-card-label-{{ ai_gen_id }}">{{ block.settings.card_label_1 }}</p>
            {% endif %}
            {% if block.settings.card_text_1 != blank %}
              <p class="ai-story-card-text-{{ ai_gen_id }}">{{ block.settings.card_text_1 }}</p>
            {% endif %}
          </div>

          {% if block.settings.show_divider %}
            <p class="ai-story-card-divider-{{ ai_gen_id }}">{{ block.settings.divider_symbol }}</p>
          {% endif %}

          <div class="ai-story-card-section-{{ ai_gen_id }}">
            {% if block.settings.card_label_2 != blank %}
              <p class="ai-story-card-label-{{ ai_gen_id }}">{{ block.settings.card_label_2 }}</p>
            {% endif %}
            {% if block.settings.card_text_2 != blank %}
              <p class="ai-story-card-text-{{ ai_gen_id }}">{{ block.settings.card_text_2 }}</p>
            {% endif %}
          </div>

          {% if block.settings.show_arrow %}
            <p class="ai-story-card-arrow-{{ ai_gen_id }}">{{ block.settings.arrow_symbol }}</p>
          {% endif %}

          <div class="ai-story-card-section-{{ ai_gen_id }}">
            {% if block.settings.card_brand != blank %}
              <p class="ai-story-card-brand-{{ ai_gen_id }}">{{ block.settings.card_brand }}</p>
            {% endif %}

            {% if block.settings.card_tagline != blank %}
              <p class="ai-story-card-tagline-{{ ai_gen_id }}">{{ block.settings.card_tagline }}</p>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</ai-story-section-{{ ai_gen_id }}>

<script>
  (function() {
    class AiStorySection{{ ai_gen_id }} extends HTMLElement {
      connectedCallback() {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          this.classList.add('ai-visible-{{ ai_gen_id }}');
          return;
        }

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('ai-visible-{{ ai_gen_id }}');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15 });

        observer.observe(this);
      }
    }

    if (!customElements.get('ai-story-section-{{ ai_gen_id }}')) {
      customElements.define('ai-story-section-{{ ai_gen_id }}', AiStorySection{{ ai_gen_id }});
    }
  })();
</script>

