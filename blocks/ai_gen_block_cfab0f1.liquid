{% doc %}
  @prompt
    Create a premium full-width "Our Mission" section for a luxury Ayurvedic hair wellness brand.

    Redesigned per brand design system: soft cream background with a low-opacity botanical
    watermark, premium feature cards with elegant outline icons (replacing emoji), soft
    shadows, hover lift, an animated gradient top-border accent, refined editorial typography,
    staggered fade-up reveal on scroll, CSS custom properties, prefers-reduced-motion support.
    Card icon settings remain in the schema for compatibility; the visible icon is now a
    curated outline SVG matched to each card's position.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-mission-section-{{ ai_gen_id }} {
    --lg-heading: {{ block.settings.heading_color }};
    --lg-gold: {{ block.settings.accent_color }};
    --lg-text: {{ block.settings.body_color }};
    --lg-card-bg: {{ block.settings.card_background }};
    --lg-card-border: {{ block.settings.card_border_color }};
    --lg-radius-card: {{ block.settings.card_radius }}px;

    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
    position: relative;
    overflow: hidden;
  }

  .ai-mission-watermark-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: -8%;
    width: 480px;
    height: 480px;
    transform: translateY(-50%);
    stroke: var(--lg-heading);
    fill: none;
    stroke-width: 1;
    opacity: 0.035;
    pointer-events: none;
  }

  .ai-mission-watermark-secondary-{{ ai_gen_id }} {
    position: absolute;
    bottom: -10%;
    right: -6%;
    width: 400px;
    height: 400px;
    stroke: var(--lg-gold);
    fill: none;
    stroke-width: 1;
    opacity: 0.035;
    pointer-events: none;
  }

  .ai-mission-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    text-align: center;
    position: relative;
  }

  .ai-mission-eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_size }}px;
    font-weight: 600;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--lg-gold);
    margin: 0 0 {{ block.settings.eyebrow_spacing }}px;
    opacity: 0;
    transform: translateY(20px);
  }

  .ai-mission-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--lg-heading);
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
    opacity: 0;
    transform: translateY(20px);
  }

  .ai-mission-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.75;
    color: var(--lg-text);
    margin: 0 0 {{ block.settings.description_spacing }}px;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
    opacity: 0;
    transform: translateY(20px);
  }

  .ai-mission-cards-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.card_gap }}px;
    margin-top: {{ block.settings.cards_top_spacing }}px;
  }

  .ai-mission-card-{{ ai_gen_id }} {
    position: relative;
    background-color: var(--lg-card-bg);
    border: {{ block.settings.card_border_width }}px solid var(--lg-card-border);
    border-radius: var(--lg-radius-card);
    padding: {{ block.settings.card_padding }}px;
    text-align: center;
    box-shadow: 0 2px 16px rgba(47, 51, 36, 0.04);
    overflow: hidden;
    opacity: 0;
    transform: translateY(30px);
    transition: transform 300ms ease, box-shadow 300ms ease;
  }

  .ai-mission-card-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--lg-gold), {{ block.settings.heading_color }});
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 400ms ease;
  }

  .ai-mission-card-{{ ai_gen_id }}:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(47, 51, 36, 0.1);
  }

  .ai-mission-card-{{ ai_gen_id }}:hover::before {
    transform: scaleX(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-mission-card-{{ ai_gen_id }} {
      transition: none;
    }

    .ai-mission-card-{{ ai_gen_id }}::before {
      transition: none;
    }
  }

  .ai-mission-card-icon-wrap-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.icon_size | plus: 28 }}px;
    height: {{ block.settings.icon_size | plus: 28 }}px;
    margin: 0 auto {{ block.settings.icon_spacing }}px;
    border-radius: 50%;
    background-color: rgba(190, 154, 92, 0.1);
    transition: background-color 300ms ease;
  }

  .ai-mission-card-{{ ai_gen_id }}:hover .ai-mission-card-icon-wrap-{{ ai_gen_id }} {
    background-color: rgba(190, 154, 92, 0.18);
  }

  .ai-mission-card-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    stroke: var(--lg-gold);
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ai-mission-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: 700;
    color: var(--lg-heading);
    margin: 0 0 {{ block.settings.card_title_spacing }}px;
  }

  .ai-mission-card-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_text_size }}px;
    line-height: 1.65;
    color: var(--lg-text);
    margin: 0;
  }

  .ai-mission-section-{{ ai_gen_id }}.ai-mission-animated-{{ ai_gen_id }} .ai-mission-eyebrow-{{ ai_gen_id }} {
    animation: ai-mission-fade-up-{{ ai_gen_id }} 0.8s ease-out forwards;
  }

  .ai-mission-section-{{ ai_gen_id }}.ai-mission-animated-{{ ai_gen_id }} .ai-mission-heading-{{ ai_gen_id }} {
    animation: ai-mission-fade-up-{{ ai_gen_id }} 0.8s ease-out 0.1s forwards;
  }

  .ai-mission-section-{{ ai_gen_id }}.ai-mission-animated-{{ ai_gen_id }} .ai-mission-description-{{ ai_gen_id }} {
    animation: ai-mission-fade-up-{{ ai_gen_id }} 0.8s ease-out 0.2s forwards;
  }

  .ai-mission-section-{{ ai_gen_id }}.ai-mission-animated-{{ ai_gen_id }} .ai-mission-card-{{ ai_gen_id }}:nth-child(1) {
    animation: ai-mission-fade-up-{{ ai_gen_id }} 0.8s ease-out 0.3s forwards;
  }

  .ai-mission-section-{{ ai_gen_id }}.ai-mission-animated-{{ ai_gen_id }} .ai-mission-card-{{ ai_gen_id }}:nth-child(2) {
    animation: ai-mission-fade-up-{{ ai_gen_id }} 0.8s ease-out 0.4s forwards;
  }

  .ai-mission-section-{{ ai_gen_id }}.ai-mission-animated-{{ ai_gen_id }} .ai-mission-card-{{ ai_gen_id }}:nth-child(3) {
    animation: ai-mission-fade-up-{{ ai_gen_id }} 0.8s ease-out 0.5s forwards;
  }

  @keyframes ai-mission-fade-up-{{ ai_gen_id }} {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-mission-eyebrow-{{ ai_gen_id }},
    .ai-mission-heading-{{ ai_gen_id }},
    .ai-mission-description-{{ ai_gen_id }},
    .ai-mission-card-{{ ai_gen_id }} {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-mission-section-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px 16px {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-mission-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-mission-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size_mobile }}px;
    }

    .ai-mission-cards-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.card_gap_mobile }}px;
    }

    .ai-mission-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding_mobile }}px;
    }
  }
{% endstyle %}

<ai-mission-section-{{ ai_gen_id }} class="ai-mission-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <svg class="ai-mission-watermark-{{ ai_gen_id }}" viewBox="0 0 200 200" aria-hidden="true" focusable="false">
    <path d="M20 180C90 170 150 120 165 40" />
    <path d="M165 40c-30 0-55-20-55-50 30 0 55 20 55 50z" />
  </svg>
  <svg class="ai-mission-watermark-secondary-{{ ai_gen_id }}" viewBox="0 0 200 200" aria-hidden="true" focusable="false">
    <path d="M40 140c-25 0-45-16-45-45 25 0 45 16 45 45z" />
    <path d="M180 20c-2 32-18 58-48 60-2-32 18-58 48-60z" />
  </svg>

  <div class="ai-mission-container-{{ ai_gen_id }}">
    {% if block.settings.eyebrow != blank %}
      <div class="ai-mission-eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow }}</div>
    {% endif %}

    {% if block.settings.heading != blank %}
      <h2 class="ai-mission-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="ai-mission-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
    {% endif %}

    <div class="ai-mission-cards-{{ ai_gen_id }}">
      <div class="ai-mission-card-{{ ai_gen_id }}">
        <div class="ai-mission-card-icon-wrap-{{ ai_gen_id }}">
          <svg class="ai-mission-card-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3 21c7-1 11-5 12-12" />
            <path d="M15 9c-3 0-5-2-5-5 3 0 5 2 5 5z" />
          </svg>
        </div>
        <h3 class="ai-mission-card-title-{{ ai_gen_id }}">{{ block.settings.card_1_title }}</h3>
        <p class="ai-mission-card-text-{{ ai_gen_id }}">{{ block.settings.card_1_text }}</p>
      </div>

      <div class="ai-mission-card-{{ ai_gen_id }}">
        <div class="ai-mission-card-icon-wrap-{{ ai_gen_id }}">
          <svg class="ai-mission-card-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M9.5 3h5M10.5 3v5.2L6 15.5A2 2 0 0 0 7.7 19h8.6a2 2 0 0 0 1.7-3.5L13.5 8.2V3" />
            <path d="M8.5 13h7" />
          </svg>
        </div>
        <h3 class="ai-mission-card-title-{{ ai_gen_id }}">{{ block.settings.card_2_title }}</h3>
        <p class="ai-mission-card-text-{{ ai_gen_id }}">{{ block.settings.card_2_text }}</p>
      </div>

      <div class="ai-mission-card-{{ ai_gen_id }}">
        <div class="ai-mission-card-icon-wrap-{{ ai_gen_id }}">
          <svg class="ai-mission-card-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 20s-7-4.35-9.5-9A5.5 5.5 0 0 1 12 6a5.5 5.5 0 0 1 9.5 5c-2.5 4.65-9.5 9-9.5 9z" />
          </svg>
        </div>
        <h3 class="ai-mission-card-title-{{ ai_gen_id }}">{{ block.settings.card_3_title }}</h3>
        <p class="ai-mission-card-text-{{ ai_gen_id }}">{{ block.settings.card_3_text }}</p>
      </div>
    </div>
  </div>
</ai-mission-section-{{ ai_gen_id }}>

<script>
  (function() {
    class AiMissionSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.hasAnimated = false;
      }

      connectedCallback() {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          return;
        }

        this.setupIntersectionObserver();
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: 0.2
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && !this.hasAnimated) {
              this.classList.add('ai-mission-animated-{{ ai_gen_id }}');
              this.hasAnimated = true;
              observer.unobserve(this);
            }
          });
        }, options);

        observer.observe(this);
      }
    }

    if (!customElements.get('ai-mission-section-{{ ai_gen_id }}')) {
      customElements.define('ai-mission-section-{{ ai_gen_id }}', AiMissionSection{{ ai_gen_id }});
    }
  })();
</script>

