{% doc %}
  @prompt
    Create a premium full-width "Our Mission" section for a luxury Ayurvedic hair wellness brand.
    
    Layout:
    - Full-width section with a soft cream background (#ECE2CE).
    - Centered content with generous whitespace.
    - Maximum content width: 900px.
    - No images on the sides.
    - Editorial, luxury magazine aesthetic.
    
    Content Structure:
    
    Small Eyebrow:
    OUR MISSION
    
    Large Heading:
    Our Mission Is Simple.
    Help People Build Healthier Hair Naturally.
    
    Below the heading, place one elegant paragraph (80–100 words) explaining that Livgenix exists to address the root causes of hair concerns by combining traditional Ayurvedic wisdom with modern scientific research, creating clean, effective formulations that support long-term hair wellness rather than temporary cosmetic fixes.
    
    Below the paragraph, display three premium pillar cards in a horizontal row (stack vertically on mobile).
    
    Card 1
    🌿
    Root Cause Approach
    We focus on nourishing hair from within instead of masking symptoms.
    
    Card 2
    ⚗️
    Science Meets Ayurveda
    Every formulation blends traditional herbal wisdom with modern research.
    
    Card 3
    ❤️
    Long-Term Wellness
    Designed to build healthier hair through consistent daily care.
    
    Style:
    - Luxury editorial design inspired by Aesop, Ritual, and Apple.
    - Large elegant typography.
    - Soft rounded cards (18–24px radius).
    - Very subtle borders (#E5DDCB).
    - No gradients.
    - No heavy shadows.
    - Plenty of whitespace (140px top and bottom padding).
    - Clean line icons.
    - Smooth fade-up animation on scroll.
    
    Color Palette:
    - Background: #ECE2CE
    - Heading: #2F3324
    - Accent: #BE9A5C
    - Body Text: #6B705C
    - Cards: White
    
    The section should feel calm, premium, trustworthy, and visually different from the About section above it.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-mission-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
  }

  .ai-mission-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    text-align: center;
  }

  .ai-mission-eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_size }}px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: {{ block.settings.accent_color }};
    margin: 0 0 {{ block.settings.eyebrow_spacing }}px;
    opacity: 0;
    transform: translateY(20px);
  }

  .ai-mission-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
    opacity: 0;
    transform: translateY(20px);
  }

  .ai-mission-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.7;
    color: {{ block.settings.body_color }};
    margin: 0 0 {{ block.settings.description_spacing }}px;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
    opacity: 0;
    transform: translateY(20px);
  }

  .ai-mission-cards-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.card_gap }}px;
    margin-top: {{ block.settings.cards_top_spacing }}px;
  }

  .ai-mission-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-align: center;
    opacity: 0;
    transform: translateY(30px);
  }

  .ai-mission-card-icon-{{ ai_gen_id }} {
    font-size: {{ block.settings.icon_size }}px;
    margin-bottom: {{ block.settings.icon_spacing }}px;
    display: block;
  }

  .ai-mission-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.card_title_spacing }}px;
  }

  .ai-mission-card-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_text_size }}px;
    line-height: 1.6;
    color: {{ block.settings.body_color }};
    margin: 0;
  }

  .ai-mission-section-{{ ai_gen_id }}.ai-mission-animated-{{ ai_gen_id }} .ai-mission-eyebrow-{{ ai_gen_id }} {
    animation: ai-mission-fade-up-{{ ai_gen_id }} 0.8s ease-out forwards;
  }

  .ai-mission-section-{{ ai_gen_id }}.ai-mission-animated-{{ ai_gen_id }} .ai-mission-heading-{{ ai_gen_id }} {
    animation: ai-mission-fade-up-{{ ai_gen_id }} 0.8s ease-out 0.1s forwards;
  }

  .ai-mission-section-{{ ai_gen_id }}.ai-mission-animated-{{ ai_gen_id }} .ai-mission-description-{{ ai_gen_id }} {
    animation: ai-mission-fade-up-{{ ai_gen_id }} 0.8s ease-out 0.2s forwards;
  }

  .ai-mission-section-{{ ai_gen_id }}.ai-mission-animated-{{ ai_gen_id }} .ai-mission-card-{{ ai_gen_id }}:nth-child(1) {
    animation: ai-mission-fade-up-{{ ai_gen_id }} 0.8s ease-out 0.3s forwards;
  }

  .ai-mission-section-{{ ai_gen_id }}.ai-mission-animated-{{ ai_gen_id }} .ai-mission-card-{{ ai_gen_id }}:nth-child(2) {
    animation: ai-mission-fade-up-{{ ai_gen_id }} 0.8s ease-out 0.4s forwards;
  }

  .ai-mission-section-{{ ai_gen_id }}.ai-mission-animated-{{ ai_gen_id }} .ai-mission-card-{{ ai_gen_id }}:nth-child(3) {
    animation: ai-mission-fade-up-{{ ai_gen_id }} 0.8s ease-out 0.5s forwards;
  }

  @keyframes ai-mission-fade-up-{{ ai_gen_id }} {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-mission-section-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px 16px {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-mission-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-mission-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size_mobile }}px;
    }

    .ai-mission-cards-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.card_gap_mobile }}px;
    }

    .ai-mission-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding_mobile }}px;
    }
  }
{% endstyle %}

<ai-mission-section-{{ ai_gen_id }} class="ai-mission-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-mission-container-{{ ai_gen_id }}">
    {% if block.settings.eyebrow != blank %}
      <div class="ai-mission-eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow }}</div>
    {% endif %}

    {% if block.settings.heading != blank %}
      <h2 class="ai-mission-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="ai-mission-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
    {% endif %}

    <div class="ai-mission-cards-{{ ai_gen_id }}">
      <div class="ai-mission-card-{{ ai_gen_id }}">
        <span class="ai-mission-card-icon-{{ ai_gen_id }}">{{ block.settings.card_1_icon }}</span>
        <h3 class="ai-mission-card-title-{{ ai_gen_id }}">{{ block.settings.card_1_title }}</h3>
        <p class="ai-mission-card-text-{{ ai_gen_id }}">{{ block.settings.card_1_text }}</p>
      </div>

      <div class="ai-mission-card-{{ ai_gen_id }}">
        <span class="ai-mission-card-icon-{{ ai_gen_id }}">{{ block.settings.card_2_icon }}</span>
        <h3 class="ai-mission-card-title-{{ ai_gen_id }}">{{ block.settings.card_2_title }}</h3>
        <p class="ai-mission-card-text-{{ ai_gen_id }}">{{ block.settings.card_2_text }}</p>
      </div>

      <div class="ai-mission-card-{{ ai_gen_id }}">
        <span class="ai-mission-card-icon-{{ ai_gen_id }}">{{ block.settings.card_3_icon }}</span>
        <h3 class="ai-mission-card-title-{{ ai_gen_id }}">{{ block.settings.card_3_title }}</h3>
        <p class="ai-mission-card-text-{{ ai_gen_id }}">{{ block.settings.card_3_text }}</p>
      </div>
    </div>
  </div>
</ai-mission-section-{{ ai_gen_id }}>

<script>
  (function() {
    class AiMissionSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.hasAnimated = false;
      }

      connectedCallback() {
        this.setupIntersectionObserver();
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: 0.2
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && !this.hasAnimated) {
              this.classList.add('ai-mission-animated-{{ ai_gen_id }}');
              this.hasAnimated = true;
              observer.unobserve(this);
            }
          });
        }, options);

        observer.observe(this);
      }
    }

    customElements.define('ai-mission-section-{{ ai_gen_id }}', AiMissionSection{{ ai_gen_id }});
  })();
</script>

