      {% if block.settings.heading != blank %}
        <h2 class="ai-faq-links-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.description != blank %}
        <div class="ai-faq-links-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
      {% endif %}
    </div>

    <div class="ai-faq-links-grid-{{ ai_gen_id }}">
      {% if block.settings.card_1_enabled %}
        <div class="ai-faq-links-card-{{ ai_gen_id }}">
          <div class="ai-faq-links-card-icon-{{ ai_gen_id }}">{{ block.settings.card_1_icon }}</div>
          <h3 class="ai-faq-links-card-title-{{ ai_gen_id }}">{{ block.settings.card_1_title }}</h3>
          <p class="ai-faq-links-card-text-{{ ai_gen_id }}">{{ block.settings.card_1_text }}</p>
          <a href="{{ block.settings.card_1_link }}" class="ai-faq-links-card-link-{{ ai_gen_id }}">
            {{ block.settings.card_1_button_text }}
            <span>→</span>
          </a>
        </div>
      {% endif %}

      {% if block.settings.card_2_enabled %}
