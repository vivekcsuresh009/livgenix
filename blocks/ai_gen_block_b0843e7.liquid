          </a>
        </div>
      {% endif %}

      {% if block.settings.card_5_enabled %}
        <div class="ai-faq-links-card-{{ ai_gen_id }}">
          <div class="ai-faq-links-card-icon-{{ ai_gen_id }}">{{ block.settings.card_5_icon }}</div>
