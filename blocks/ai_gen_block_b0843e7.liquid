{% doc %}
  @prompt
    Create a premium "FAQ Quick Links" section for a luxury Ayurvedic hair wellness brand
    called Livgenix.

    Redesigned per brand design system: premium monochrome outline SVG icons replacing
    emoji, animated sliding arrow, rounded cards with soft shadow and hover lift, refined
    typography hierarchy, consistent spacing, CSS custom properties, prefers-reduced-motion
    support. Card icon/title/text/link settings remain fully editable and compatible.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-faq-links-{{ ai_gen_id }} {
    --lg-heading: {{ block.settings.heading_color }};
    --lg-gold: {{ block.settings.accent_color }};
    --lg-eyebrow: {{ block.settings.eyebrow_color }};
    --lg-text: {{ block.settings.body_text_color }};
    --lg-card-bg: {{ block.settings.card_background }};
    --lg-card-border: {{ block.settings.card_border_color }};
    --lg-radius-card: {{ block.settings.card_border_radius }}px;

    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-faq-links-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-faq-links-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-faq-links-eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_size }}px;
    color: var(--lg-eyebrow);
    letter-spacing: 2.5px;
    text-transform: uppercase;
    margin-bottom: 16px;
    font-weight: 600;
  }

  .ai-faq-links-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: var(--lg-heading);
    margin: 0 0 20px;
    font-weight: 700;
    line-height: 1.2;
  }

  .ai-faq-links-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: var(--lg-text);
    line-height: 1.7;
    max-width: 700px;
    margin: 0 auto;
  }

  .ai-faq-links-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: {{ block.settings.card_gap }}px;
    margin-top: {{ block.settings.grid_spacing }}px;
  }

  .ai-faq-links-card-{{ ai_gen_id }} {
    background-color: var(--lg-card-bg);
    border: {{ block.settings.card_border_width }}px solid var(--lg-card-border);
    border-radius: var(--lg-radius-card);
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    box-shadow: 0 2px 14px rgba(47, 51, 36, 0.04);
    transition: transform 300ms ease, box-shadow 300ms ease, border-color 300ms ease;
  }

  .ai-faq-links-card-{{ ai_gen_id }}:hover,
  .ai-faq-links-card-{{ ai_gen_id }}:focus-within {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px rgba(47, 51, 36, 0.1);
    border-color: rgba(190, 154, 92, 0.35);
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-faq-links-card-{{ ai_gen_id }} {
      transition: none;
    }
  }

  .ai-faq-links-card-icon-wrap-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.icon_size | plus: 24 }}px;
    height: {{ block.settings.icon_size | plus: 24 }}px;
    border-radius: 50%;
    background-color: rgba(190, 154, 92, 0.1);
    transition: background-color 300ms ease;
  }

  .ai-faq-links-card-{{ ai_gen_id }}:hover .ai-faq-links-card-icon-wrap-{{ ai_gen_id }} {
    background-color: rgba(190, 154, 92, 0.18);
  }

  .ai-faq-links-card-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    stroke: var(--lg-gold);
    fill: none;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ai-faq-links-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    color: var(--lg-heading);
    margin: 0;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .ai-faq-links-card-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_text_size }}px;
    color: var(--lg-text);
    line-height: 1.6;
    margin: 0;
    flex-grow: 1;
  }

  .ai-faq-links-card-link-{{ ai_gen_id }} {
    font-size: {{ block.settings.link_size }}px;
    color: var(--lg-gold);
    text-decoration: none;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .ai-faq-links-card-link-arrow-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: transform 300ms ease;
  }

  .ai-faq-links-card-link-{{ ai_gen_id }}:hover .ai-faq-links-card-link-arrow-{{ ai_gen_id }},
  .ai-faq-links-card-link-{{ ai_gen_id }}:focus-visible .ai-faq-links-card-link-arrow-{{ ai_gen_id }} {
    transform: translateX(5px);
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-faq-links-card-link-arrow-{{ ai_gen_id }} {
      transition: none;
    }
  }

  .ai-faq-links-card-link-{{ ai_gen_id }}:focus-visible {
    outline: 2px solid var(--lg-gold);
    outline-offset: 3px;
    border-radius: 4px;
  }

  @media screen and (max-width: 749px) {
    .ai-faq-links-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.card_gap | times: 0.75 }}px;
    }

    .ai-faq-links-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-faq-links-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .ai-faq-links-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    .ai-faq-links-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
    }
  }
{% endstyle %}

