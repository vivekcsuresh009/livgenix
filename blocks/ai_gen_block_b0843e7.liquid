          <div class="ai-faq-links-card-icon-{{ ai_gen_id }}">{{ block.settings.card_3_icon }}</div>
          <h3 class="ai-faq-links-card-title-{{ ai_gen_id }}">{{ block.settings.card_3_title }}</h3>
          <p class="ai-faq-links-card-text-{{ ai_gen_id }}">{{ block.settings.card_3_text }}</p>
          <a href="{{ block.settings.card_3_link }}" class="ai-faq-links-card-link-{{ ai_gen_id }}">
            {{ block.settings.card_3_button_text }}
            <span>→</span>
          </a>
        </div>
      {% endif %}

      {% if block.settings.card_4_enabled %}
        <div class="ai-faq-links-card-{{ ai_gen_id }}">
          <div class="ai-faq-links-card-icon-{{ ai_gen_id }}">{{ block.settings.card_4_icon }}</div>
