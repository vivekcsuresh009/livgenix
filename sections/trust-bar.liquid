{% comment %}
  ==========================================================================
  Section: Trust Bar
  File: sections/trust-bar.liquid

  Premium, minimal trust-signal strip for the Livgenix homepage (sits under
  the Hero). Icons are drawn once as an inline SVG <symbol> sprite and
  referenced with <use> to avoid duplicating markup per card. No external
  libraries or JS frameworks; the only animation is a CSS-only, progressively
  enhanced scroll reveal (animation-timeline: view()) that no-ops safely in
  browsers/reduced-motion contexts that don't support it.
  ==========================================================================
{% endcomment %}

{% liquid
  assign heading_id = 'TrustBarHeading-' | append: section.id
%}

<section
  class="trust-bar"
  id="trust-bar-{{ section.id }}"
  {% if section.settings.heading != blank %}
    aria-labelledby="{{ heading_id }}"
  {% else %}
    aria-label="Why customers trust Livgenix"
  {% endif %}
>
  {% comment %} Shared icon sprite, defined once, referenced via <use> {% endcomment %}
  <svg aria-hidden="true" style="position: absolute; width: 0; height: 0; overflow: hidden;">
    <symbol id="trust-bar-icon-leaf-{{ section.id }}" viewBox="0 0 24 24">
      <path d="M3 21c7-1 11-5 12-12" />
      <path d="M15 9c-3 0-5-2-5-5 3 0 5 2 5 5z" />
    </symbol>
    <symbol id="trust-bar-icon-microscope-{{ section.id }}" viewBox="0 0 24 24">
      <path d="M8 21h8" />
      <path d="M12 21v-5" />
      <path d="M9 12a3 3 0 1 1 6 0c0 1.5-1 2.5-2 3.5l-1 1.5-1-1.5c-1-1-2-2-2-3.5z" />
      <path d="M13 6l3-2" />
      <path d="M11 4l2 2-2 2-2-2z" />
    </symbol>
    <symbol id="trust-bar-icon-shield-{{ section.id }}" viewBox="0 0 24 24">
      <path d="M12 3l7 3v6c0 4.5-3 8-7 9-4-1-7-4.5-7-9V6l7-3z" />
      <path d="M9.25 12l1.85 1.85L15 10" />
    </symbol>
    <symbol id="trust-bar-icon-heart-{{ section.id }}" viewBox="0 0 24 24">
      <path d="M12 20s-7-4.35-9.5-9A5.5 5.5 0 0 1 12 6a5.5 5.5 0 0 1 9.5 5c-2.5 4.65-9.5 9-9.5 9z" />
    </symbol>
    <symbol id="trust-bar-icon-location_pin-{{ section.id }}" viewBox="0 0 24 24">
      <path d="M12 21s-6.5-5.7-6.5-11A6.5 6.5 0 0 1 18.5 10c0 5.3-6.5 11-6.5 11z" />
      <circle cx="12" cy="10" r="2.3" />
    </symbol>
    <symbol id="trust-bar-icon-droplet-{{ section.id }}" viewBox="0 0 24 24">
      <path d="M12 3c3.5 4 6 7.2 6 10.3A6 6 0 1 1 6 13.3C6 10.2 8.5 7 12 3z" />
    </symbol>
  </svg>

  <div class="trust-bar__container">
    {% if section.settings.heading != blank %}
      <h2 id="{{ heading_id }}" class="trust-bar__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}

    <ul class="trust-bar__list" role="list">
      {% for block in section.blocks %}
        {% liquid
          assign icon_key = block.settings.icon
          if icon_key == blank
            assign icon_key = 'leaf'
          endif
        %}
        <li
          class="trust-bar__card"
          style="--trust-bar-card-delay: {{ forloop.index0 | times: 60 }}ms;"
          {{ block.shopify_attributes }}
        >
          <span class="trust-bar__icon-wrap" aria-hidden="true">
            <svg class="trust-bar__icon" viewBox="0 0 24 24">
              <use href="#trust-bar-icon-{{ icon_key }}-{{ section.id }}"></use>
            </svg>
          </span>

          {% if block.settings.heading != blank %}
            <h3 class="trust-bar__card-heading">{{ block.settings.heading | escape }}</h3>
          {% endif %}

          {% if block.settings.text != blank %}
            <p class="trust-bar__card-text">{{ block.settings.text | escape }}</p>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
</section>

{% style %}
  .trust-bar {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .trust-bar__container {
    max-width: 1280px;
    margin: 0 auto;
    padding-inline: 24px;
  }

  .trust-bar__heading {
    margin: 0 0 40px;
    text-align: center;
    font-size: 1.75rem;
    font-weight: 600;
    line-height: 1.2;
    color: {{ section.settings.heading_color }};
  }

  .trust-bar__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .trust-bar__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
    text-align: center;
    background-color: {{ section.settings.card_background_color }};
    border-radius: 24px;
    padding: 32px 20px;
    box-shadow: 0 2px 16px rgba(43, 43, 43, 0.05);
    transition: transform 300ms ease, box-shadow 300ms ease;
  }

  .trust-bar__card:hover,
  .trust-bar__card:focus-within {
    transform: translateY(-6px);
    box-shadow: 0 16px 32px rgba(43, 43, 43, 0.1);
  }

  .trust-bar__icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    margin-bottom: 20px;
    border-radius: 50%;
    background-color: {{ section.settings.icon_background_color }};
    transition: background-color 300ms ease;
  }

  .trust-bar__card:hover .trust-bar__icon-wrap,
  .trust-bar__card:focus-within .trust-bar__icon-wrap {
    background-color: #234536;
  }

  .trust-bar__icon {
    width: 28px;
    height: 28px;
    stroke: #234536;
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: stroke 300ms ease;
  }

  .trust-bar__card:hover .trust-bar__icon,
  .trust-bar__card:focus-within .trust-bar__icon {
    stroke: #ffffff;
  }

  .trust-bar__card-heading {
    margin: 0 0 8px;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
    color: {{ section.settings.heading_color }};
  }

  .trust-bar__card-text {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.5;
    color: {{ section.settings.text_color }};
  }

  /* Progressive-enhancement scroll reveal: no scroll-reveal system exists
     elsewhere in this theme, so this stays CSS-only and self-contained.
     Base state is fully visible, so unsupported browsers and
     prefers-reduced-motion see the section normally with zero JS. */
  @supports (animation-timeline: view()) {
    @media (prefers-reduced-motion: no-preference) {
      .trust-bar__card {
        animation: trust-bar-fade-in linear both;
        animation-timeline: view();
        animation-range: entry 0% cover 25%;
        animation-delay: var(--trust-bar-card-delay, 0ms);
      }
    }
  }

  @keyframes trust-bar-fade-in {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (min-width: 750px) {
    .trust-bar__list {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    .trust-bar__heading {
      font-size: 2rem;
    }

    .trust-bar__list {
      grid-template-columns: repeat(6, 1fr);
      gap: 24px;
    }

    .trust-bar__card {
      padding: 32px 16px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Trust Bar",
  "tag": "section",
  "class": "shopify-section--trust-bar",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Optional. Leave blank to hide."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FAF7F2"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "icon_background_color",
      "label": "Icon background color",
      "default": "#E7EEE7"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#2B2B2B"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body text color",
      "default": "#6E6E6E"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top spacing",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "default": 70
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom spacing",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "default": 70
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "leaf", "label": "Leaf" },
            { "value": "microscope", "label": "Microscope" },
            { "value": "shield", "label": "Shield" },
            { "value": "heart", "label": "Heart" },
            { "value": "location_pin", "label": "Location pin" },
            { "value": "droplet", "label": "Droplet" }
          ],
          "default": "leaf"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "100% Herbal"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Supporting text",
          "default": "Carefully selected Ayurvedic herbs."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon": "leaf",
            "heading": "100% Herbal",
            "text": "Carefully selected Ayurvedic herbs."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "microscope",
            "heading": "Science-Informed",
            "text": "Traditional wisdom backed by modern research."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "shield",
            "heading": "Quality Tested",
            "text": "Manufactured under strict quality standards."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "heart",
            "heading": "Holistic Wellness",
            "text": "Supporting hair health from the inside out."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "location_pin",
            "heading": "Made in India",
            "text": "Inspired by authentic Ayurvedic traditions."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "droplet",
            "heading": "No Harsh Chemicals",
            "text": "Free from sulfates, parabens and silicones.*"
          }
        }
      ]
    }
  ]
}
{% endschema %}
