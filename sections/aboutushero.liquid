{% comment %}
  ==========================================================================
  Section: Custom Empathy Hero
  File: sections/custom-empathy-hero.liquid

  A full-width image hero with a tinted overlay, eyebrow label, bold
  headline with an underline accent, supporting copy, a CTA button, and an
  optional trust badge image. Built for Shopify Horizon (OS 2.0).

  - No color_scheme / scheme classes used — all colors are section settings.
  - No external libraries or fonts — vanilla CSS/JS only.
  - Fully scoped to {{ section.id }} so nothing leaks globally.
  ==========================================================================
{% endcomment %}

<section
  class="empathy-hero empathy-hero--{{ section.id }}"
  id="empathy-hero-{{ section.id }}"
  aria-label="{{ section.settings.heading | strip_html | escape }}"
>
  <div class="empathy-hero__frame">

    {% comment %} Background image (desktop + optional mobile override) {% endcomment %}
    <div class="empathy-hero__media" aria-hidden="true">
      {% if section.settings.image_desktop != blank %}
        <img
          class="empathy-hero__img empathy-hero__img--desktop"
          src="{{ section.settings.image_desktop | image_url: width: 2400 }}"
          srcset="
            {{ section.settings.image_desktop | image_url: width: 800 }} 800w,
            {{ section.settings.image_desktop | image_url: width: 1200 }} 1200w,
            {{ section.settings.image_desktop | image_url: width: 1600 }} 1600w,
            {{ section.settings.image_desktop | image_url: width: 2000 }} 2000w,
            {{ section.settings.image_desktop | image_url: width: 2400 }} 2400w
          "
          sizes="100vw"
          alt="{{ section.settings.image_desktop.alt | default: section.settings.heading | escape }}"
          width="{{ section.settings.image_desktop.width }}"
          height="{{ section.settings.image_desktop.height }}"
          loading="eager"
          fetchpriority="high"
        >
      {% else %}
        <div class="empathy-hero__img empathy-hero__img--placeholder empathy-hero__img--desktop">
          {{ 'lifestyle-1' | placeholder_svg_tag: 'empathy-hero__placeholder-svg' }}
        </div>
      {% endif %}

      {% if section.settings.image_mobile != blank %}
        <img
          class="empathy-hero__img empathy-hero__img--mobile"
          src="{{ section.settings.image_mobile | image_url: width: 1200 }}"
          srcset="
            {{ section.settings.image_mobile | image_url: width: 600 }} 600w,
            {{ section.settings.image_mobile | image_url: width: 900 }} 900w,
            {{ section.settings.image_mobile | image_url: width: 1200 }} 1200w
          "
          sizes="100vw"
          alt="{{ section.settings.image_mobile.alt | default: section.settings.heading | escape }}"
          width="{{ section.settings.image_mobile.width }}"
          height="{{ section.settings.image_mobile.height }}"
          loading="eager"
          fetchpriority="high"
        >
      {% endif %}

      <div class="empathy-hero__tint"></div>
      <div class="empathy-hero__bar empathy-hero__bar--top"></div>
      <div class="empathy-hero__bar empathy-hero__bar--bottom"></div>
    </div>

    {% comment %} Content {% endcomment %}
    <div class="empathy-hero__container">
      <div class="empathy-hero__content">

        {% if section.settings.eyebrow != blank %}
          <p class="empathy-hero__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="empathy-hero__heading">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.show_divider %}
          <div class="empathy-hero__divider" role="presentation"></div>
        {% endif %}

        {% if section.settings.body != blank %}
          <div class="empathy-hero__body">{{ section.settings.body }}</div>
        {% endif %}

        {% if section.settings.button_label != blank %}
          
            href="{{ section.settings.button_link | default: '#' }}"
            class="empathy-hero__button"
            {% if section.settings.button_link == blank %}role="link" aria-disabled="true"{% endif %}
          >
            <span>{{ section.settings.button_label | escape }}</span>{% if section.settings.button_superscript != blank %}<sup>{{ section.settings.button_superscript | escape }}</sup>{% endif %}
          </a>
        {% endif %}

      </div>

      {% if section.settings.show_badge and section.settings.badge_image != blank %}
        <div class="empathy-hero__badge">
          <img
            src="{{ section.settings.badge_image | image_url: width: 400 }}"
            srcset="
              {{ section.settings.badge_image | image_url: width: 160 }} 160w,
              {{ section.settings.badge_image | image_url: width: 240 }} 240w,
              {{ section.settings.badge_image | image_url: width: 320 }} 320w
            "
            sizes="(max-width: 749px) 96px, 140px"
            alt="{{ section.settings.badge_image.alt | default: 'Trust badge' | escape }}"
            width="{{ section.settings.badge_image.width }}"
            height="{{ section.settings.badge_image.height }}"
            loading="lazy"
          >
        </div>
      {% endif %}
    </div>

    {% comment %} Optional scroll/progress indicator dot (visual only, decorative like reference) {% endcomment %}
    {% if section.settings.show_scroll_indicator %}
      <div class="empathy-hero__scroll-indicator" aria-hidden="true">
        <span></span>
      </div>
    {% endif %}

  </div>
</section>

<style>
  .empathy-hero--{{ section.id }} {
    --eh-max-width: {{ section.settings.section_max_width }}px;
    --eh-content-max-width: {{ section.settings.content_max_width }}px;
    --eh-radius: {{ section.settings.corner_radius }}px;

    --eh-pad-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --eh-pad-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --eh-pad-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --eh-pad-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;

    --eh-side-pad-desktop: {{ section.settings.side_padding_desktop }}px;
    --eh-side-pad-mobile: {{ section.settings.side_padding_mobile }}px;

    --eh-min-height-desktop: {{ section.settings.min_height_desktop }}px;
    --eh-min-height-mobile: {{ section.settings.min_height_mobile }}px;

    --eh-tint-color: {{ section.settings.tint_color }};
    --eh-tint-opacity: {{ section.settings.tint_opacity | divided_by: 100.0 }};
    --eh-bar-color: {{ section.settings.bar_color }};
    --eh-bar-height: {{ section.settings.bar_height }}px;

    --eh-eyebrow-color: {{ section.settings.eyebrow_color }};
    --eh-heading-color: {{ section.settings.heading_color }};
    --eh-body-color: {{ section.settings.body_color }};
    --eh-divider-color: {{ section.settings.divider_color }};

    --eh-button-bg: {{ section.settings.button_background }};
    --eh-button-bg-hover: {{ section.settings.button_background_hover }};
    --eh-button-text: {{ section.settings.button_text_color }};

    display: block;
    width: 100%;
    padding-top: var(--eh-pad-top-mobile);
    padding-bottom: var(--eh-pad-bottom-mobile);
    background: {{ section.settings.section_background }};
    box-sizing: border-box;
  }

  .empathy-hero--{{ section.id }} * {
    box-sizing: border-box;
  }

  .empathy-hero--{{ section.id }} .empathy-hero__frame {
    position: relative;
    width: 100%;
    max-width: var(--eh-max-width);
    margin: 0 auto;
    border-radius: var(--eh-radius);
    overflow: hidden;
    isolation: isolate;
  }

  /* ---------------------------------------------------------------------
     Media / background image layer
  --------------------------------------------------------------------- */
  .empathy-hero--{{ section.id }} .empathy-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .empathy-hero--{{ section.id }} .empathy-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ section.settings.image_position }};
    display: block;
  }

  .empathy-hero--{{ section.id }} .empathy-hero__img--placeholder {
    background: #dfe3d8;
  }

  .empathy-hero--{{ section.id }} .empathy-hero__img--placeholder svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .empathy-hero--{{ section.id }} .empathy-hero__img--mobile {
    display: none;
  }

  .empathy-hero--{{ section.id }} .empathy-hero__tint {
    position: absolute;
    inset: 0;
    background: var(--eh-tint-color);
    opacity: var(--eh-tint-opacity);
    mix-blend-mode: {{ section.settings.tint_blend_mode }};
  }

  .empathy-hero--{{ section.id }} .empathy-hero__bar {
    position: absolute;
    left: 0;
    right: 0;
    height: var(--eh-bar-height);
    background: var(--eh-bar-color);
  }

  .empathy-hero--{{ section.id }} .empathy-hero__bar--top {
    top: 0;
  }

  .empathy-hero--{{ section.id }} .empathy-hero__bar--bottom {
    bottom: 0;
  }

  /* ---------------------------------------------------------------------
     Content layer
  --------------------------------------------------------------------- */
  .empathy-hero--{{ section.id }} .empathy-hero__container {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    width: 100%;
    min-height: var(--eh-min-height-mobile);
    padding: var(--eh-pad-top-mobile) var(--eh-side-pad-mobile) var(--eh-pad-bottom-mobile);
  }

  .empathy-hero--{{ section.id }} .empathy-hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    max-width: var(--eh-content-max-width);
    width: 100%;
  }

  .empathy-hero--{{ section.id }} .empathy-hero__eyebrow {
    margin: 0 0 12px;
    font-size: 16px;
    font-weight: 800;
    line-height: 1.2;
    color: var(--eh-eyebrow-color);
    letter-spacing: 0.01em;
  }

  .empathy-hero--{{ section.id }} .empathy-hero__heading {
    margin: 0;
    font-size: {{ section.settings.heading_size_mobile }}px;
    font-weight: 800;
    line-height: 1.12;
    color: var(--eh-heading-color);
    letter-spacing: -0.01em;
  }

  .empathy-hero--{{ section.id }} .empathy-hero__divider {
    width: 56px;
    height: 4px;
    margin-top: 20px;
    border-radius: 2px;
    background: var(--eh-divider-color);
  }

  .empathy-hero--{{ section.id }} .empathy-hero__body {
    margin-top: 20px;
    font-size: 16px;
    line-height: 1.55;
    color: var(--eh-body-color);
    max-width: 46ch;
  }

  .empathy-hero--{{ section.id }} .empathy-hero__body p {
    margin: 0;
  }

  .empathy-hero--{{ section.id }} .empathy-hero__body p + p {
    margin-top: 12px;
  }

  /* ---------------------------------------------------------------------
     Button
  --------------------------------------------------------------------- */
  .empathy-hero--{{ section.id }} .empathy-hero__button {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-top: 24px;
    padding: 16px 28px;
    background: var(--eh-button-bg);
    color: var(--eh-button-text);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: {{ section.settings.button_radius }}px;
    border: none;
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
  }

  .empathy-hero--{{ section.id }} .empathy-hero__button sup {
    font-size: 10px;
    margin-left: 1px;
    top: -0.6em;
  }

  .empathy-hero--{{ section.id }} .empathy-hero__button:hover {
    background: var(--eh-button-bg-hover);
    transform: translateY(-1px);
  }

  .empathy-hero--{{ section.id }} .empathy-hero__button:focus-visible {
    outline: 2px solid var(--eh-button-bg);
    outline-offset: 3px;
  }

  /* ---------------------------------------------------------------------
     Badge
  --------------------------------------------------------------------- */
  .empathy-hero--{{ section.id }} .empathy-hero__badge {
    flex-shrink: 0;
    width: 96px;
    height: 96px;
    opacity: 0.92;
    align-self: flex-end;
  }

  .empathy-hero--{{ section.id }} .empathy-hero__badge img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  /* ---------------------------------------------------------------------
     Scroll indicator (decorative)
  --------------------------------------------------------------------- */
  .empathy-hero--{{ section.id }} .empathy-hero__scroll-indicator {
    position: absolute;
    bottom: calc(var(--eh-bar-height) + 10px);
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    width: 40px;
    height: 4px;
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.35);
    overflow: hidden;
  }

  .empathy-hero--{{ section.id }} .empathy-hero__scroll-indicator span {
    display: block;
    width: 40%;
    height: 100%;
    background: rgba(255, 255, 255, 0.9);
    border-radius: 2px;
  }

  /* ---------------------------------------------------------------------
     Desktop breakpoint
  --------------------------------------------------------------------- */
  @media screen and (min-width: 750px) {
    .empathy-hero--{{ section.id }} {
      padding-top: var(--eh-pad-top-desktop);
      padding-bottom: var(--eh-pad-bottom-desktop);
    }

    .empathy-hero--{{ section.id }} .empathy-hero__container {
      align-items: flex-end;
      min-height: var(--eh-min-height-desktop);
      padding: var(--eh-pad-top-desktop) var(--eh-side-pad-desktop) var(--eh-pad-bottom-desktop);
    }

    .empathy-hero--{{ section.id }} .empathy-hero__heading {
      font-size: {{ section.settings.heading_size_desktop }}px;
    }

    .empathy-hero--{{ section.id }} .empathy-hero__badge {
      width: 140px;
      height: 140px;
    }

    .empathy-hero--{{ section.id }} .empathy-hero__body {
      font-size: 18px;
    }

    {% if section.settings.image_mobile != blank %}
      .empathy-hero--{{ section.id }} .empathy-hero__img--desktop {
        display: block;
      }
      .empathy-hero--{{ section.id }} .empathy-hero__img--mobile {
        display: none;
      }
    {% endif %}
  }

  /* Mobile: swap in mobile-specific crop if one was uploaded */
  {% if section.settings.image_mobile != blank %}
    @media screen and (max-width: 749px) {
      .empathy-hero--{{ section.id }} .empathy-hero__img--desktop {
        display: none;
      }
      .empathy-hero--{{ section.id }} .empathy-hero__img--mobile {
        display: block;
      }
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    .empathy-hero--{{ section.id }} .empathy-hero__container {
      flex-direction: column;
      align-items: flex-start;
      gap: 32px;
    }

    .empathy-hero--{{ section.id }} .empathy-hero__badge {
      align-self: flex-start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .empathy-hero--{{ section.id }} .empathy-hero__button {
      transition: none;
    }
  }
</style>

{% schema %}
{
  "name": "Custom Empathy Hero",
  "tag": "section",
  "class": "section-custom-empathy-hero",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "We Empathise"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Scientific solutions to stubborn hair problems</p>"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show divider under heading",
      "default": true
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text",
      "default": "<p>Livgenix was born of a quest to find a scientific, herbal-first solution to a stubborn problem that many people face: hair fall.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Take the Hair Test"
    },
    {
      "type": "text",
      "id": "button_superscript",
      "label": "Button superscript text",
      "default": "TM",
      "info": "Optional small superscript, e.g. a trademark symbol"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Background image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Background image (mobile)",
      "info": "Optional. If left blank, the desktop image is used and cropped for mobile."
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image focal point",
      "options": [
        { "value": "top left", "label": "Top left" },
        { "value": "top center", "label": "Top center" },
        { "value": "top right", "label": "Top right" },
        { "value": "center left", "label": "Center left" },
        { "value": "center center", "label": "Center" },
        { "value": "center right", "label": "Center right" },
        { "value": "bottom left", "label": "Bottom left" },
        { "value": "bottom center", "label": "Bottom center" },
        { "value": "bottom right", "label": "Bottom right" }
      ],
      "default": "center center"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show trust badge",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "badge_image",
      "label": "Trust badge image"
    },
    {
      "type": "checkbox",
      "id": "show_scroll_indicator",
      "label": "Show decorative scroll indicator bar",
      "default": true
    },
    {
      "type": "header",
      "content": "Overlay & bars"
    },
    {
      "type": "color",
      "id": "tint_color",
      "label": "Image tint color",
      "default": "#6b7a4f"
    },
    {
      "type": "range",
      "id": "tint_opacity",
      "label": "Tint opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 55
    },
    {
      "type": "select",
      "id": "tint_blend_mode",
      "label": "Tint blend mode",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "multiply", "label": "Multiply" },
        { "value": "color", "label": "Color" },
        { "value": "overlay", "label": "Overlay" }
      ],
      "default": "multiply"
    },
    {
      "type": "color",
      "id": "bar_color",
      "label": "Top/bottom bar color",
      "default": "#20241c"
    },
    {
      "type": "range",
      "id": "bar_height",
      "label": "Top/bottom bar height",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#23271d"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body text color",
      "default": "#f4f5f0"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider color",
      "default": "#23271d"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#33362d"
    },
    {
      "type": "color",
      "id": "button_background_hover",
      "label": "Button background (hover)",
      "default": "#484c3e"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Layout & width"
    },
    {
      "type": "range",
      "id": "section_max_width",
      "label": "Section max width",
      "min": 1000,
      "max": 1920,
      "step": 20,
      "unit": "px",
      "default": 1920,
      "info": "Set to 1920 or higher for an edge-to-edge full-width hero"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 320,
      "max": 900,
      "step": 10,
      "unit": "px",
      "default": 620
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Section corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Height"
    },
    {
      "type": "range",
      "id": "min_height_desktop",
      "label": "Minimum height (desktop)",
      "min": 400,
      "max": 900,
      "step": 10,
      "unit": "px",
      "default": 680
    },
    {
      "type": "range",
