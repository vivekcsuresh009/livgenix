                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Yes. Our formulations are designed to be suitable for most hair types, including straight, wavy, curly, and textured hair. Individual results may vary depending on your hair condition and routine.</p>",
