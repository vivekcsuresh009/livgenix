              },
              "blocks": {
                "text": {
                  "type": "text",
                  "settings": {
                    "text": "<p>LiveGenix combines science-backed formulations with carefully selected ingredients to support healthier hair from root to tip. Every product is developed with a focus on performance, quality, and long-term hair wellness.</p>",
